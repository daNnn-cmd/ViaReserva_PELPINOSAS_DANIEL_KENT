@model ViaReservaERP.Models.Admin.AccountingDashboardViewModel
@{
    ViewData["Title"] = "Accounting Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@functions {
    string DeltaClass(double? pct)
    {
        if (!pct.HasValue) return "vr-sa-kpi-delta vr-sa-kpi-delta-na";
        if (pct.Value > 0.0001) return "vr-sa-kpi-delta vr-sa-kpi-delta-up";
        if (pct.Value < -0.0001) return "vr-sa-kpi-delta vr-sa-kpi-delta-down";
        return "vr-sa-kpi-delta";
    }

    string DeltaText(double? pct)
    {
        if (!pct.HasValue) return "—";
        var sign = pct.Value > 0 ? "+" : "";
        return $"{sign}{pct.Value:0.0}%";
    }
}

<div class="vr-sa-reports">
    <!-- Financial KPI Grid -->
    <div class="vr-sa-grid" style="margin-bottom: 20px;">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">TOTAL SETTLED</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.TotalRevenue.ToString("N0")</div>
                    <div class="@DeltaClass(Model.TotalRevenueDeltaPct)">@DeltaText(Model.TotalRevenueDeltaPct) vs prev month</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.08);"><i class="fa-solid fa-vault"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Total guest payments (MTD)</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">SERVICE INCOME</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.ServiceRevenue.ToString("N0")</div>
                    <div class="@DeltaClass(Model.ServiceRevenueDeltaPct)">@DeltaText(Model.ServiceRevenueDeltaPct) vs prev month</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-file-invoice-dollar"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Ancillary & service revenue</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">COLLECTED VAT (12%)</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.TotalTax.ToString("N0")</div>
                    <div class="@DeltaClass(Model.TotalTaxDeltaPct)">@DeltaText(Model.TotalTaxDeltaPct) vs prev month</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #64748b; background: rgba(100, 116, 139, 0.08);"><i class="fa-solid fa-percent"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Government tax collection</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">SERVICE CHARGES (10%)</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.TotalServiceCharge.ToString("N0")</div>
                    <div class="@DeltaClass(Model.TotalServiceChargeDeltaPct)">@DeltaText(Model.TotalServiceChargeDeltaPct) vs prev month</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #64748b; background: rgba(100, 116, 139, 0.08);"><i class="fa-solid fa-hand-holding-dollar"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Total hospitality fees</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">PENDING SETTLEMENT</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.PendingPayments.ToString("N0")</div>
                    <div class="@DeltaClass(Model.PendingPaymentsDeltaPct)">@DeltaText(Model.PendingPaymentsDeltaPct) vs prev month</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-hourglass-half"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Awaiting payment completion</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">NET PROFIT</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.NetProfit.ToString("N0")</div>
                    <div class="@DeltaClass(Model.NetProfitDeltaPct)">@DeltaText(Model.NetProfitDeltaPct) vs prev month</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #c9a227; background: rgba(201, 162, 39, 0.08);"><i class="fa-solid fa-scale-balanced"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Income after operating expenses</div>
        </div>
    </div>

    <!-- Filter Bar -->
    <section class="vr-sa-panel vr-sa-reports-filters" style="margin-bottom:24px;">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Analytics Time Range</div>
                <div class="vr-sa-panel-sub">Selected: <span style="font-weight:500; color:#0b122d;">@Model.SelectedRangeLabel</span></div>
            </div>
        </div>
        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Granularity</div>
                <select class="vr-sa-filter-input" name="granularity" onchange="this.form.submit()">
                    <option value="day" selected="@(Model.Granularity == "day")">Day</option>
                    <option value="month" selected="@(Model.Granularity == "month")">Month</option>
                    <option value="year" selected="@(Model.Granularity == "year")">Year</option>
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Year</div>
                <select class="vr-sa-filter-input" name="year" onchange="this.form.submit()">
                    <option value="">Select Year</option>
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                    {
                        <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
                    }
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Start</div>
                <input class="vr-sa-filter-input" type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">End</div>
                <input class="vr-sa-filter-input" type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("Dashboard", "Accounting")">Reset</a>
                </div>
            </div>
        </form>
    </section>

    <!-- Analytics Panels -->
    <div class="vr-sa-panels">
        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">Revenue Trends</div>
                    <div class="vr-sa-panel-sub">Monthly settlement volume (last 6 months)</div>
                </div>
            </div>
            <div class="vr-sa-chart vr-sa-chart-compact">
                <div id="vrAccRevenueChart" class="vr-sa-apex"></div>
            </div>
        </section>

        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">Profit & Loss Analysis</div>
                    <div class="vr-sa-panel-sub">Income vs Expenses vs Net Profit</div>
                </div>
            </div>
            <div class="vr-sa-chart vr-sa-chart-compact">
                <div id="vrAccFinancialChart" class="vr-sa-apex"></div>
            </div>
        </section>
    </div>

    <div class="row g-4 mt-2">
        <!-- Recent Ledger -->
        <div class="col-lg-8">
            <section class="vr-sa-panel h-100">
                <div class="vr-sa-panel-head">
                    <div>
                        <div class="vr-sa-panel-title">Accounting Ledger</div>
                        <div class="vr-sa-panel-sub">Latest financial recorded entries</div>
                    </div>
                </div>

                <div class="vr-sa-table-wrap vr-sa-table-modern">
                    <table class="vr-sa-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Details</th>
                                <th class="vr-sa-cell-center">Type</th>
                                <th class="vr-sa-cell-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight: 500; color: #0b122d;">@t.TransactionDate.ToString("MMM dd")</div>
                                        <div class="vr-sa-cell-muted" style="font-size: 0.8rem;">@t.TransactionDate.ToString("t")</div>
                                    </td>
                                    <td>
                                        <div style="font-weight: 700; color: #0b122d;">@t.Description</div>
                                        <div class="vr-sa-cell-muted" style="font-size: 0.8rem;">#@t.ReferenceId (@t.ReferenceType)</div>
                                    </td>
                                    <td class="vr-sa-cell-center">
                                        <div style="font-weight: 600; font-size: 0.7rem; text-transform: uppercase;">@t.Type</div>
                                    </td>
                                    <td class="vr-sa-cell-right">
                                        <div style="font-weight: 800; color: @(t.Type == "Income" ? "#10b981" : "#ef4444");">
                                            @(t.Type == "Income" ? "+" : "-") ₱ @t.Amount?.ToString("N2")
                                        </div>
                                        @if (t.TaxAmount > 0 || t.ServiceCharge > 0)
                                        {
                                            <div style="font-size: 0.72rem; color: #64748b; margin-top: 2px;">
                                                VAT: ₱@t.TaxAmount?.ToString("N2")<br/>
                                                SC: ₱@t.ServiceCharge?.ToString("N2")
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!Model.RecentTransactions.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 vr-sa-cell-muted">No transactions found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="vr-sa-pagination p-3 pt-0">
                        <div class="vr-sa-cell-muted">Page @Model.Page of @Model.TotalPages</div>
                        <div class="vr-sa-pagination-actions">
                            <a class="vr-sa-pagebtn" href="@Url.Action("Dashboard", "Accounting", new { page = Model.Page - 1 })" aria-disabled="@(Model.Page <= 1)">Prev</a>
                            <a class="vr-sa-pagebtn" href="@Url.Action("Dashboard", "Accounting", new { page = Model.Page + 1 })" aria-disabled="@(Model.Page >= Model.TotalPages)">Next</a>
                        </div>
                    </div>
                }
            </section>
        </div>

        <!-- Recent Payments -->
        <div class="col-lg-4">
            <section class="vr-sa-panel h-100">
                <div class="vr-sa-panel-head">
                    <div>
                        <div class="vr-sa-panel-title">Recent Payments</div>
                        <div class="vr-sa-panel-sub">Latest guest settlements</div>
                    </div>
                </div>
                <div class="p-3">
                    @foreach (var p in Model.RecentPayments)
                    {
                        <div class="d-flex align-items-center p-3 mb-2" style="background: rgba(15, 23, 42, 0.02); border-radius: 12px; border: 1px solid rgba(15, 23, 42, 0.04);">
                            <div class="vr-sa-ico vr-sa-ico-slate me-3" style="width: 38px; height: 38px;"><i class="fa-solid fa-credit-card"></i></div>
                            <div class="flex-grow-1">
                                <div style="font-weight: 700; color: #0b122d; font-size: 0.9rem;">₱ @p.Amount?.ToString("N2")</div>
                                <div class="vr-sa-cell-muted" style="font-size: 0.72rem;">@p.PaymentMethod • @p.CreatedAt.ToString("MMM dd, hh:mm tt")</div>
                            </div>
                            <div style="font-size: 0.7rem; font-weight: 800; color: @(p.Status == "Succeeded" ? "#10b981" : "#f59e0b"); text-transform: uppercase;">@p.Status</div>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @{
        var jsonOpts = new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web);
    }
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.49.1"></script>
    <script>
        (function () {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            const palette = {
                blue: '#1a2a6c',
                gold: '#c9a227',
                emerald: '#10b981',
                red: '#ef4444',
                grid: isDark ? 'rgba(255, 255, 255, 0.06)' : 'rgba(30, 41, 59, 0.08)',
                muted: isDark ? '#94a3b8' : '#64748b'
            };

            function baseOptions() {
                return {
                    chart: { toolbar: { show: false }, foreColor: palette.muted, fontFamily: 'Inter, system-ui, sans-serif' },
                    grid: { borderColor: palette.grid, strokeDashArray: 4 },
                    legend: { position: 'bottom' },
                    tooltip: { theme: isDark ? 'dark' : 'light' },
                    dataLabels: { enabled: false }
                };
            }

            const revenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueAnalytics, jsonOpts));
            const financial = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FinancialAnalytics, jsonOpts));

            // Revenue Chart
            const revEl = document.querySelector('#vrAccRevenueChart');
            if (revEl) {
                const opt = baseOptions();
                opt.chart.type = 'area';
                opt.chart.height = 240;
                opt.stroke = { curve: 'smooth', width: 2 };
                opt.fill = { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.05 } };
                opt.colors = [palette.emerald];
                opt.series = [{ name: 'Revenue', data: revenue.datasets['Revenue'] || [] }];
                opt.xaxis = { categories: revenue.labels || [] };
                new ApexCharts(revEl, opt).render();
            }

            // Financial Chart
            const finEl = document.querySelector('#vrAccFinancialChart');
            if (finEl) {
                const opt = baseOptions();
                opt.chart.type = 'line';
                opt.chart.height = 240;
                opt.stroke = { curve: 'smooth', width: [3, 3, 2], dashArray: [0, 0, 5] };
                opt.colors = [palette.blue, palette.red, palette.gold];
                opt.series = [
                    { name: 'Income', type: 'column', data: financial.datasets['Income'] || [] },
                    { name: 'Expenses', type: 'column', data: financial.datasets['Expenses'] || [] },
                    { name: 'Net Profit', type: 'line', data: financial.datasets['Net Profit'] || [] }
                ];
                opt.plotOptions = { bar: { borderRadius: 4, columnWidth: '50%' } };
                opt.xaxis = { categories: financial.labels || [] };
                new ApexCharts(finEl, opt).render();
            }
        })();
    </script>
}

@model ViaReservaERP.Models.Admin.AdminNotificationsViewModel

@if (Model.Items.Count == 0)
{
    <div style="padding: 40px; text-align: center; color: rgba(15, 23, 42, 0.5);">
        <div style="font-size: 3rem; margin-bottom: 16px; opacity: 0.3;">
            <i class="fa-solid fa-file-invoice-dollar"></i>
        </div>
        <div style="font-weight: 600; font-size: 1.1rem;">No accounting notifications</div>
        <p>You'll receive updates here about payments, transactions, and financial reports.</p>
    </div>
}
else
{
    foreach (var item in Model.Items)
    {
        var icon = "fa-bell";
        var color = "#3b82f6";
        var bg = "rgba(59, 130, 246, 0.1)";

        var title = (item.Title ?? "").ToLower();
        var message = (item.Message ?? "").ToLower();

        if (title.Contains("payment") || title.Contains("transaction") || title.Contains("refund") || message.Contains("payment") || message.Contains("transaction"))
        {
            icon = "fa-money-bill-transfer";
            color = "#10b981"; // Emerald
            bg = "rgba(16, 185, 129, 0.1)";
        }
        else if (title.Contains("invoice") || title.Contains("bill") || title.Contains("charge"))
        {
            icon = "fa-file-invoice-dollar";
            color = "#6366f1"; // Indigo
            bg = "rgba(99, 102, 241, 0.1)";
        }
        else if (title.Contains("audit") || title.Contains("accounting"))
        {
            icon = "fa-receipt";
            color = "#8b5cf6"; // Violet
            bg = "rgba(139, 92, 246, 0.1)";
        }
        else if (title.Contains("security") || title.Contains("alert"))
        {
            icon = "fa-shield-halved";
            color = "#e11d48"; // Rose
            bg = "rgba(225, 29, 72, 0.1)";
        }
        else if (title.Contains("approval") || (item.Type ?? "") == "Workflow")
        {
            icon = "fa-stamp";
            color = "#f59e0b"; // Amber
            bg = "rgba(245, 158, 11, 0.1)";
        }

        <div style="padding: 20px; border-bottom: 1px solid rgba(15, 23, 42, 0.06); display: flex; align-items: flex-start; gap: 16px; @(item.IsRead ? "" : "background: rgba(15, 23, 42, 0.01);")">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: @bg; color: @color; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <i class="fa-solid @icon"></i>
            </div>
            <div style="flex-grow: 1;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <div style="font-weight: 600; color: #0b122d; font-size: 0.95rem;">@item.Title</div>
                    @if (!item.IsRead)
                    {
                        <div style="font-size: 0.8rem; color: @color; font-weight: 500;">New</div>
                    }
                </div>
                <div style="color: rgba(15, 23, 42, 0.7); font-size: 0.9rem; margin-bottom: 4px;">@item.Message</div>
                <div style="font-size: 0.8rem; color: rgba(15, 23, 42, 0.5);">@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
        </div>
    }
}

@using ViaReservaERP.Models
@model ViaReservaERP.Models.Reservations.BookReservationViewModel
@{
    ViewData["Title"] = "Book Reservation";
    ViewData["PageSubtitle"] = "Find your perfect stay";
    var bookingUiDataJson = ViewData["BookingUiDataJson"] as string ?? "{}";
    var stripePublishableKey = ViewData["StripePublishableKey"] as string ?? string.Empty;
    var currentUserEmail = User?.Identity?.IsAuthenticated == true ? (User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty) : string.Empty;
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var isGuest = isAuthenticated && User.HasRoleId(6);
    if (isGuest)
    {
        Layout = "~/Views/Shared/_GuestLayout.cshtml";
        ViewData["BodyClass"] = "";
    }
    else
    {
        ViewData["BodyClass"] = "vr-book-body";
    }
}

<style>
    /* Premium SaaS overrides for Booking Page */
    :root {
        --vr-navy: #0f2d57;
        --vr-gold: #c5a365;
        --vr-blue: #1e40af;
        --vr-light: #f8fafc;
    }
    .vr-book-body {
        background-color: var(--vr-light);
        font-family: 'Inter', sans-serif;
    }
    .vr-book {
        padding: 40px 20px 80px;
        min-height: 100vh;
    }
    .vr-book-container {
        max-width: 1200px;
        margin: 0 auto;
    }
    /* Header */
    .vr-book-header {
        background: linear-gradient(135deg, var(--vr-navy) 0%, var(--vr-blue) 100%);
        border-radius: 20px;
        padding: 40px;
        color: white;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(15,45,87,0.15);
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .vr-book-header::after {
        content: '';
        position: absolute;
        top: 0; right: 0; bottom: 0; left: 0;
        background: url('/img/login-bg-modern.png') no-repeat center center;
        background-size: cover;
        opacity: 0.15;
        mix-blend-mode: overlay;
        pointer-events: none;
    }
    .vr-book-brand {
        display: flex;
        align-items: center;
        gap: 20px;
        position: relative;
        z-index: 2;
    }
    .vr-book-logo {
        height: 60px;
        background: white;
        padding: 10px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .vr-book-kicker {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 800;
        color: var(--vr-gold);
        margin-bottom: 5px;
    }
    .vr-book-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;




    /* Service Card Specifics */
    .vr-service-card {
        padding: 12px 20px !important;
        flex-direction: row !important;
        align-items: center !important;
        min-height: 80px;
        gap: 15px;
        border: 2px solid #e2e8f0;
    }
    .vr-service-icon {
        width: 45px;
        height: 45px;
        background: #f1f5f9;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: var(--vr-gold);
        transition: background 0.3s;
    }
    .vr-book-option-selected .vr-service-icon {
        background: rgba(197,163,101,0.15);
    }
    .vr-service-body {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: left;
    }


        font-weight: 800;
        margin: 0;
        color: white;
    }
    /* Grid Layout */
    .vr-book-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
        align-items: start;
    }
    /* Cards */
    .vr-book-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 20px rgba(15,45,87,0.05);
        border: 1px solid rgba(15,45,87,0.05);
        margin-bottom: 20px;
    }
    /* Progress Bar */
    .vr-book-progress {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .vr-book-progress-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--vr-navy);
        margin-top: 5px;
    }
    .vr-book-pills {
        display: flex;
        gap: 8px;
    }
    .vr-book-pill {
        min-width: 78px;
        height: 44px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        background: var(--vr-light);
        color: #64748b;
        transition: all 0.3s;
        border: 1px solid rgba(15,45,87,0.10);
        flex-direction: column;
        line-height: 1.1;
        cursor: pointer;
        user-select: none;
    }
    .vr-book-pill .vr-book-pill-num {
        font-size: 0.85rem;
        font-weight: 900;
    }
    .vr-book-pill .vr-book-pill-label {
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.9;
    }
    .vr-book-pill-active {
        background: var(--vr-navy);
        color: white;
        box-shadow: 0 4px 10px rgba(15,45,87,0.2);
        border-color: rgba(15,45,87,0.25);
    }
    .vr-book-pill-complete {
        background: rgba(34,197,94,0.10);
        color: #16a34a;
        border-color: rgba(34,197,94,0.25);
        box-shadow: none;
    }
    .vr-book-pill-disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }
    /* Typography */
    .vr-book-section-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--vr-navy);
    }
    .vr-book-muted {
        color: #64748b;
        font-size: 0.95rem;
    }
    /* Options (Hotels, Rooms, Services) */
    .vr-book-select-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }
    .vr-book-option {
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .vr-book-option:hover {
        border-color: rgba(197,163,101,0.5);
        background: #fdfcfa;
        transform: translateY(-2px);
    }
    .vr-book-option-selected {
        border-color: var(--vr-navy);
        background: #f8fafc;
        box-shadow: 0 4px 15px rgba(15,45,87,0.08);
    }
    .vr-book-option-title {
        font-weight: 700;
        color: var(--vr-navy);
        font-size: 1.1rem;
        margin-bottom: 5px;
    }
    .vr-book-option-sub {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.4;
    }
    /* Image Card Specifics */
    .vr-image-card {
        padding: 0;
        overflow: hidden;
        flex-direction: column;
        align-items: stretch;
        min-height: 220px;
        border: 2px solid #e2e8f0;
    }
    .vr-card-img-wrap {
        height: 160px;
        position: relative;
        overflow: hidden;
    }
    .vr-card-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s;
    }
    .vr-image-card:hover .vr-card-img-wrap img {
        transform: scale(1.05);
    }
    .vr-card-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(15,45,87,0.85) 0%, rgba(15,45,87,0.3) 50%, transparent 100%);
    }
    .vr-card-img-title {
        position: absolute;
        bottom: 15px;
        left: 15px;
        right: 15px;
        color: white;
        font-weight: 800;
        font-size: 1.15rem;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
    .vr-card-img-price {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--vr-gold);
        color: var(--vr-navy);
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 800;
        font-size: 0.9rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
    .vr-card-body-simple {
        padding: 15px;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: white;
    }
    .vr-room-card-tag {
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
        background: #f1f5f9;
        padding: 4px 10px;
        border-radius: 6px;
        display: flex;
        align-items: center;
    }
    .vr-book-option-selected {
        border-color: var(--vr-gold);
        background: #fdfcfa;
        box-shadow: 0 8px 25px rgba(197,163,101,0.15);
    }
    .vr-book-option-selected .vr-card-img-overlay {
        background: linear-gradient(to top, var(--vr-navy) 0%, rgba(15,45,87,0.4) 100%);
    }
    /* Forms */
    .vr-book-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 20px;
    }
    .vr-book-field label {
        font-weight: 600;
        color: var(--vr-navy);
        margin-bottom: 8px;
        display: block;
    }
    .vr-book-input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background: #f8fafc;
        font-family: inherit;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .vr-book-input:focus {
        outline: none;
        border-color: var(--vr-gold);
        background: white;
        box-shadow: 0 0 0 3px rgba(197,163,101,0.2);
    }
    /* Buttons */
    .vr-book-actions {
        margin-top: 30px;
        display: flex;
        justify-content: flex-end;
    }
    .vr-book-btn {
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }
    .vr-book-btn-primary {
        background: var(--vr-navy);
        color: white;
    }
    .vr-book-btn-primary:hover {
        background: var(--vr-blue);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(15,45,87,0.2);
    }
    .vr-book-btn-danger {
        background: var(--vr-gold);
        color: var(--vr-navy);
    }
    .vr-book-btn-danger:hover {
        background: #d4b57b;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(197,163,101,0.3);
    }
    .vr-book-btn:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }
    .vr-book-page-indicator {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 800;
        align-self: center;
        margin: 0 6px;
    }
    .vr-book-page-dots {
        display: flex;
        gap: 6px;
        align-items: center;
        justify-content: center;
        margin-top: 10px;
    }
    .vr-book-page-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #e2e8f0;
        border: 1px solid rgba(15,45,87,0.10);
        cursor: pointer;
    }
    .vr-book-page-dot-active {
        background: var(--vr-navy);
        border-color: rgba(15,45,87,0.25);
    }
    .vr-book-link {
        color: var(--vr-gold);
        background: none;
        border: none;
        font-weight: 700;
        text-decoration: underline;
        cursor: pointer;
        padding: 0;
    }
    .vr-book-link:hover {
        color: #d4b57b;
    }
    /* Sidebar Summary */
    .vr-book-summary {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 20px rgba(15,45,87,0.05);
        border: 1px solid rgba(15,45,87,0.05);
        position: sticky;
        top: 20px;
    }
    .vr-book-summary-badge {
        background: rgba(197,163,101,0.1);
        color: var(--vr-gold);
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
    }
    .vr-book-summary-row {
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #e2e8f0;
    }
    .vr-book-summary-label {
        font-weight: 800;
        color: var(--vr-navy);
        font-size: 0.85rem;
        text-transform: uppercase;
        margin-bottom: 4px;
    }
    .vr-book-summary-value {
        font-weight: 700;
        color: #334155;
        font-size: 1.05rem;
    }
    .vr-book-summary-sub {
        color: #64748b;
        font-size: 0.9rem;
    }
    @@media (max-width: 992px) {
        .vr-book-grid {
            grid-template-columns: 1fr;
        }
        .vr-book-summary {
            position: relative;
            top: 0;
        }
        .vr-book-fields {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="vr-book">
    <div class="vr-book-container">
        <div class="vr-book-header">
            <div class="vr-book-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" class="vr-book-logo" />
                <div>
                    <div class="vr-book-kicker">Booking</div>
                    <h1 class="vr-book-title">Book your stay</h1>
                </div>
            </div>

        </div>

        <div class="vr-book-grid">
            <div>
                <div class="vr-book-card">
                    <div class="vr-book-progress">
                        <div>
                            <div class="vr-book-muted" style="font-weight:800;">Progress</div>
                            <div id="bkStepTitle" class="vr-book-progress-title">Step 1: Choose a hotel</div>
                        </div>

                        <div class="vr-book-pills" aria-label="Steps">
                            <div id="bkStepPill1" class="vr-book-pill vr-book-pill-active" role="button" tabindex="0" data-step="1">
                                <div class="vr-book-pill-num">1</div>
                                <div class="vr-book-pill-label">Hotel</div>
                            </div>
                            <div id="bkStepPill2" class="vr-book-pill" role="button" tabindex="0" data-step="2">
                                <div class="vr-book-pill-num">2</div>
                                <div class="vr-book-pill-label">Room</div>
                            </div>
                            <div id="bkStepPill3" class="vr-book-pill" role="button" tabindex="0" data-step="3">
                                <div class="vr-book-pill-num">3</div>
                                <div class="vr-book-pill-label">Extras</div>
                            </div>
                            <div id="bkStepPill4" class="vr-book-pill" role="button" tabindex="0" data-step="4">
                                <div class="vr-book-pill-num">4</div>
                                <div class="vr-book-pill-label">Guest</div>
                            </div>
                            <div id="bkStepPill5" class="vr-book-pill" role="button" tabindex="0" data-step="5">
                                <div class="vr-book-pill-num">5</div>
                                <div class="vr-book-pill-label">Review</div>
                            </div>
                            <div id="bkStepPill6" class="vr-book-pill" role="button" tabindex="0" data-step="6">
                                <div class="vr-book-pill-num">6</div>
                                <div class="vr-book-pill-label">Payment</div>
                            </div>
                        </div>
                    </div>
                </div>

                <form id="bkForm" style="margin-top:14px;" asp-action="Book" asp-controller="Reservation" method="post">
                    @Html.AntiForgeryToken()

                    @if (!ViewContext.ModelState.IsValid)
                    {
                        <div class="vr-book-card" style="background:#fef2f2;border-color:#fca5a5;margin-bottom:14px;">
                            <div style="font-weight:800;color:#dc2626;margin-bottom:6px;">Booking Error</div>
                            <div asp-validation-summary="All" class="text-danger" style="font-size:14px;"></div>
                        </div>
                    }

                    <input asp-for="CompanyId" id="bkCompanyId" type="hidden" />

                    <input type="hidden" id="bkSelectedRoomTypeId" name="SelectedRoomTypeId" />
                    <input asp-for="SelectedRoomId" id="bkSelectedRoomId" type="hidden" />
                    <input type="hidden" id="bkSelectedRoomTypePrice" name="SelectedRoomTypePrice" />
                    <input asp-for="SelectedServicesJson" id="bkSelectedServicesJson" type="hidden" />
                    <input asp-for="StripePaymentIntentId" id="bkStripePaymentIntentId" type="hidden" />
                    <input asp-for="DemoPayment" id="bkDemoPayment" type="hidden" />

                    <section id="bkStep1" class="vr-book-card">
                        <div class="vr-book-muted" style="font-weight:800;">Hotel selection</div>
                        <div class="vr-book-section-title">Pick where you want to stay</div>
                        <div class="vr-book-muted" style="margin-top:6px;">Choose dates first to check room availability across our hotels.</div>

                        <div class="vr-book-fields" style="margin-top:12px;">
                            <div class="vr-book-field">
                                <label asp-for="CheckInDate">Check-in</label>
                                <input asp-for="CheckInDate" id="bkCheckIn" class="vr-book-input" />
                                <span asp-validation-for="CheckInDate" class="text-danger"></span>
                            </div>
                            <div class="vr-book-field">
                                <label asp-for="CheckOutDate">Check-out</label>
                                <input asp-for="CheckOutDate" id="bkCheckOut" class="vr-book-input" />
                                <span asp-validation-for="CheckOutDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div id="bkAvailHint" class="vr-book-muted" style="margin-top:10px;">Select dates to load availability.</div>
                        <div id="bkAvailError" class="vr-hidden text-danger" style="margin-top:10px;"></div>

                        <div id="bkHotels" class="vr-book-select-grid"></div>
                        <div id="bkHotelsPagination" class="d-flex gap-2 justify-content-center mt-3" style="display:none;"></div>

                        <div style="margin-top:10px;">
                            <span asp-validation-for="CompanyId" class="text-danger"></span>
                        </div>
                    </section>

                    <section id="bkStep2" class="vr-book-card vr-hidden" style="margin-top:14px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                            <div>
                                <div class="vr-book-muted" style="font-weight:800;">Room selection</div>
                                <div class="vr-book-section-title">Choose your room</div>
                                <div id="bkSelectedHotelIndicator" class="vr-hidden" style="margin-top: 4px; font-size: 0.9rem; color: #64748b; font-weight: 600;">
                                    Selected Property: <span id="bkSelectedHotelName" style="color: var(--vr-navy); font-weight: 800;"></span>
                                </div>

                                <div class="vr-book-muted" style="margin-top:6px;">Prices are per night. Availability is based on rooms marked Available.</div>
                            </div>
                            <button type="button" id="bkBackToHotels" class="vr-book-link">Change hotel</button>
                        </div>

                        <div id="bkRooms" class="vr-book-select-grid"></div>

                        <div id="bkRoomsEmpty" class="vr-book-card vr-hidden" style="margin-top:14px;background:#f8fafc;border-color:rgba(15,23,42,0.08);">
                            No available rooms found for this hotel.
                        </div>
                    </section>

                    <section id="bkStep3" class="vr-book-card vr-hidden" style="margin-top:14px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                            <div>
                                <div class="vr-book-muted" style="font-weight:800;">Optional services</div>
                                <div class="vr-book-section-title">Add services to enhance your stay</div>
                                <div class="vr-book-muted" style="margin-top:6px;">Services depend on the selected hotel.</div>
                            </div>
                            <button type="button" id="bkBackToRooms" class="vr-book-link">Back</button>
                        </div>

                        <div id="bkServices" class="vr-book-select-grid"></div>

                        <div id="bkServicesEmpty" class="vr-hidden" style="margin-top:14px;">
                            No services configured for this hotel.
                        </div>

                        <div class="vr-book-actions">
                            <button type="button" id="bkToGuest" class="vr-book-btn vr-book-btn-primary">Continue</button>
                        </div>
                    </section>

                    <section id="bkStep4" class="vr-book-card vr-hidden" style="margin-top:14px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                            <div>
                                <div class="vr-book-muted" style="font-weight:800;">Guest information</div>
                                <div class="vr-book-section-title">Tell us who’s staying</div>
                                <div class="vr-book-muted" style="margin-top:6px;">We’ll create (or verify) your guest account during booking.</div>
                            </div>
                            <button type="button" id="bkBackToServices" class="vr-book-link">Back</button>
                        </div>

                        <div class="vr-book-fields">
                            <div class="vr-book-field">
                                <label asp-for="FullName"></label>
                                <input asp-for="FullName" class="vr-book-input" autocomplete="name" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="vr-book-field">
                                <label asp-for="Email"></label>
                                <input asp-for="Email" class="vr-book-input" autocomplete="email" inputmode="email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="vr-book-field">
                                <label asp-for="Phone"></label>
                                <input asp-for="Phone" class="vr-book-input" autocomplete="tel" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <div class="vr-book-field">
                                <label asp-for="Password"></label>
                                <input asp-for="Password" class="vr-book-input" type="password" autocomplete="new-password" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="vr-book-actions">
                            <button type="button" id="bkToDates" class="vr-book-btn vr-book-btn-primary">Continue</button>
                        </div>
                    </section>

                    <section id="bkStep5" class="vr-book-card vr-hidden" style="margin-top:14px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                            <div>
                                <div class="vr-book-muted" style="font-weight:800;">Review</div>
                                <div class="vr-book-section-title">Review your details</div>
                                <div class="vr-book-muted" style="margin-top:6px;">Continue to payment on the next step.</div>
                            </div>
                            <button type="button" id="bkBackToGuest" class="vr-book-link">Back</button>
                        </div>

                        <div class="vr-book-fields" style="margin-top:18px; grid-template-columns: 1.2fr 0.8fr;">
                            <div class="vr-book-card" style="background:#f8fafc;border-color:rgba(15,23,42,0.08);margin-bottom:0;">
                                <div class="vr-book-muted" style="font-weight:800;">Booking details</div>

                                <div class="vr-book-fields" style="margin-top:10px; grid-template-columns: 1fr 1fr;">
                                    <div>
                                        <div class="vr-book-summary-label">Hotel</div>
                                        <div id="bkStep5Hotel" class="vr-book-summary-value"></div>
                                        <div id="bkStep5HotelAddress" class="vr-book-summary-sub"></div>
                                    </div>
                                    <div>
                                        <div class="vr-book-summary-label">Room</div>
                                        <div id="bkStep5Room" class="vr-book-summary-value"></div>
                                        <div id="bkStep5RoomMeta" class="vr-book-summary-sub"></div>

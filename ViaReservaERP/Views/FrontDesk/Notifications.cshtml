@model ViaReservaERP.Models.Admin.AdminNotificationsViewModel
@{
    Layout = "_AdminLayout";
}

<div style="margin-bottom: 24px; text-align: right;">
    <form method="post" action="@Url.Action("MarkAllAsRead", "FrontDesk")">
        @Html.AntiForgeryToken()
        <button type="submit" class="vr-sa-btn">Mark All as Read</button>
    </form>
</div>

<div class="vr-sa-card" style="padding: 0;">
    <div id="vrFrontDeskNotificationsList" style="display: flex; flex-direction: column;">
        <partial name="_NotificationsList" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const list = document.getElementById('vrFrontDeskNotificationsList');

            async function refreshNotifications() {
                try {
                    const resp = await fetch('@Url.Action("NotificationsListPartial", "FrontDesk")', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (!resp.ok) return;
                    const html = await resp.text();
                    if (list) list.innerHTML = html;
                } catch (e) {
                    // swallow
                }
            }

            // Poll every 10s for near real-time updates
            setInterval(refreshNotifications, 10000);
        })();
    </script>
}

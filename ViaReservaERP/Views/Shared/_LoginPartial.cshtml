<ul class="navbar-nav">
@if (User?.Identity?.IsAuthenticated == true)
{
    <li class="nav-item">
        <span class="nav-link text-dark">Hello @User.Identity?.Name!</span>
    </li>
    <li class="nav-item">
        <form class="form-inline" method="post" action="@Url.Action("Logout", "Account")">
            @Html.AntiForgeryToken()
            <button type="button" class="nav-link btn btn-link text-dark" data-bs-toggle="modal" data-bs-target="#vrLogoutConfirmModal">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" href="@Url.Action("Login", "Account")">Login</a>
    </li>
}
</ul>

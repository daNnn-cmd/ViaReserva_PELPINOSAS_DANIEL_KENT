<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ViaReservaERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/tailwind-output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ViaReservaERP.styles.css" asp-append-version="true" />
</head>
<body class="@(ViewData["BodyClass"] as string ?? string.Empty)">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/viareserva-logo.png" alt="ViaReserva" style="height:28px;width:auto;" />
                    <span>ViaReserva</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            @* Company Admin (RoleId = 2) *@
                            if (User.HasRoleId(2))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Company" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Company" asp-action="Staff">Staff Management</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Company" asp-action="Reports">Reports</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Company" asp-action="Subscription">Subscription Status</a>
                                </li>
                            }

                            @* Front Desk (RoleId = 4) *@
                            if (User.HasRoleId(4))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="FrontDesk" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="FrontDesk" asp-action="CheckInOut">Check-in/out</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="FrontDesk" asp-action="Reservations">Reservations</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="FrontDesk" asp-action="Guests">Guests</a>
                                </li>
                            }

                            @* Service Staff (RoleId = 5) *@
                            if (User.HasRoleId(5))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ServiceStaff" asp-action="Requests">My Service Requests</a>
                                </li>
                            }

                            @* Accountant (RoleId = 3) *@
                            if (User.HasRoleId(3))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Accounting" asp-action="Reports">Financial Reports</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Accounting" asp-action="Transactions">Transactions</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Accounting" asp-action="Payments">Payments</a>
                                </li>
                            }

                            @* Guests (RoleId = 6) *@
                            if (User.HasRoleId(6))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Guest" asp-action="Reservations">My Reservations</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Guest" asp-action="Services">Request Services</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Guest" asp-action="Bills">My Bills</a>
                                </li>
                            }
                        }
                    </ul>
                    @{
                        var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
                        var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);
                        var isLandingPage = controller.Equals("Home", StringComparison.OrdinalIgnoreCase)
                            && action.Equals("Index", StringComparison.OrdinalIgnoreCase);
                    }

                    @if (isLandingPage)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <partial name="_LoginPartial" />
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="modal fade vr-sa-logout-modal" id="vrLogoutConfirmModal" tabindex="-1" aria-labelledby="vrLogoutConfirmTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="vrLogoutConfirmTitle">Confirm Logout</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to log out of your account?
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" action="@Url.Action("Logout", "Account")">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="vr-sa-btn vr-sa-btn-danger">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

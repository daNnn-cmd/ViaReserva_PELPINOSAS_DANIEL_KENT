@model ViaReservaERP.Models.Admin.PaymentViewModel

<div class="modal-header">
    <div>
        <h5 class="modal-title" style="font-weight: 700; color: #0b122d;">Process Payment</h5>
        <div class="vr-sa-cell-muted">Reservation #@Model.ReservationId — @Model.GuestName</div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<form action="@Url.Action("ProcessPayment", "Admin")" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ReservationId" />
    <input type="hidden" asp-for="GuestName" />
    <input type="hidden" asp-for="TotalAmount" />
    <input type="hidden" asp-for="AlreadyPaid" />

    <div class="modal-body">
        <div class="vr-sa-panel" style="background: rgba(15, 23, 42, 0.02); margin-bottom: 20px; border: 1px dashed rgba(15, 23, 42, 0.1);">
            <div class="row text-center">
                <div class="col-6" style="border-right: 1px solid rgba(15, 23, 42, 0.1);">
                    <div class="vr-sa-label">Total Amount</div>
                    <div style="font-weight: 700; color: #0b122d;">₱ @Model.TotalAmount.ToString("N2")</div>
                </div>
                <div class="col-6">
                    <div class="vr-sa-label">Balance Due</div>
                    <div style="font-weight: 800; color: #ef4444;">₱ @Model.RemainingBalance.ToString("N2")</div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-12">
                <label class="vr-sa-label">Payment Type</label>
                <select asp-for="PaymentType" class="vr-sa-input">
                    <option value="Full">Full Payment</option>
                    <option value="Deposit">Deposit</option>
                    <option value="Partial">Partial Payment</option>
                    <option value="Refund">Refund</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="vr-sa-label">Amount to Process</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">₱</span>
                    <input asp-for="PaymentAmount" type="number" step="0.01" class="vr-sa-input border-start-0" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" />
                </div>
            </div>
            <div class="col-md-6">
                <label class="vr-sa-label">Method</label>
                <select asp-for="PaymentMethod" class="vr-sa-input">
                    <option value="Cash">Cash</option>
                    <option value="Credit Card">Credit Card</option>
                    <option value="Bank Transfer">Bank Transfer</option>
                    <option value="Stripe">Stripe (Online)</option>
                </select>
            </div>
            <div class="col-md-12">
                <label class="vr-sa-label">Reference / Note (Optional)</label>
                <input asp-for="Reference" class="vr-sa-input" placeholder="e.g. OR# 12345" />
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="vr-sa-btn vr-sa-btn-primary">
            <i class="fa-solid fa-file-invoice-dollar me-2"></i> Submit Payment
        </button>
    </div>
</form>

@model ViaReservaERP.Models.SuperAdmin.EnterpriseInquiriesViewModel
@{
    ViewData["Title"] = "Enterprise Inquiries";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

@functions {
    private static readonly TimeZoneInfo PhTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Singapore Standard Time");

    string PhTime(DateTime dt)
    {
        var utc = DateTime.SpecifyKind(dt, DateTimeKind.Utc);
        return TimeZoneInfo.ConvertTimeFromUtc(utc, PhTimeZone).ToString("yyyy-MM-dd HH:mm");
    }
}

<style>
    .vr-inquiry-table thead th {
        font-weight: 800;
        color: #0f172a;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding-bottom: 12px;
        border-bottom: 2px solid #f1f5f9;
    }
    .vr-inquiry-row-main td {
        padding-top: 16px;
        padding-bottom: 8px;
        border-bottom: none;
    }
    .vr-inquiry-row-detail td {
        padding-top: 0;
        padding-bottom: 16px;
        border-bottom: 1px solid #f1f5f9;
    }
    .vr-inquiry-msg-box {
        background: #f8fafc;
        border-left: 3px solid #cbd5e1;
        padding: 12px 16px;
        border-radius: 0 8px 8px 0;
        margin-left: 20px;
        color: #475569;
        font-size: 0.92rem;
        line-height: 1.5;
    }
    .vr-inquiry-sub-msg {
        margin-top: 8px;
        font-size: 0.82rem;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .vr-status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .vr-status-badge.new { background: #dcfce7; color: #15803d; }
    .vr-status-badge.contacted { background: #fef9c3; color: #a16207; }
    .vr-status-badge.closed { background: #f1f5f9; color: #64748b; }
</style>

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Inquiries</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalInquiries</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-inbox"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">All non-archived enterprise leads</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">New</div>
                    <div class="vr-sa-report-stat-value">@Model.NewInquiries</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-circle-plus"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Awaiting initial contact</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Contacted</div>
                    <div class="vr-sa-report-stat-value">@Model.ContactedInquiries</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-phone"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">In progress</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Closed</div>
                    <div class="vr-sa-report-stat-value">@Model.ClosedInquiries</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #64748b; background: rgba(100, 116, 139, 0.08);"><i class="fa-solid fa-circle-check"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Resolved leads</div>
        </div>
    </div>

    <section class="vr-sa-panel vr-sa-reports-filters">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Filters</div>
                <div class="vr-sa-panel-sub">Search and status filtering for enterprise inquiries.</div>
            </div>
        </div>

        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Search</div>
                <input class="vr-sa-filter-input" name="search" value="@Model.Search" placeholder="Company, contact, email, phone" />
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Status</div>
                <select class="vr-sa-filter-input" name="status">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Status))">All</option>
                    <option value="New" selected="@(Model.Status == "New")">New</option>
                    <option value="Contacted" selected="@(Model.Status == "Contacted")">Contacted</option>
                    <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Page Size</div>
                <select class="vr-sa-filter-input" name="pageSize">
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>

            <input type="hidden" name="page" value="1" />

            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("EnterpriseInquiries", "SuperAdmin")">Reset</a>
                </div>
            </div>
        </form>
    </section>

    <section class="vr-sa-panel" style="margin-top: 16px;">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Inquiry Inbox</div>
                <div class="vr-sa-panel-sub">Most recent inquiries first.</div>
            </div>
            <div class="vr-sa-pill">@Model.TotalRows total</div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle vr-inquiry-table">
                <thead>
                    <tr>
                        <th style="width: 180px;">Submitted</th>
                        <th>Company</th>
                        <th>Contact</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-center">Branches</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center vr-muted" style="padding: 24px;">No inquiries found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var r in Model.Rows)
                        {
                            <tr class="vr-inquiry-row-main">
                                <td style="white-space: nowrap; font-weight: 600; color: #64748b;">@PhTime(r.CreatedAt)</td>
                                <td style="font-weight: 800; color: #0b122d;">@r.CompanyName</td>
                                <td style="font-weight: 600; color: #334155;">@r.ContactPerson</td>
                                <td>@r.Email</td>
                                <td>@r.Phone</td>
                                <td class="text-center" style="font-weight: 700;">@r.NumberOfBranches</td>
                                <td class="text-center">
                                    @{
                                        var s = (r.Status ?? "New").ToLowerInvariant();
                                        var badgeClass = s == "new" ? "new" : s == "contacted" ? "contacted" : "closed";
                                    }
                                    <span class="vr-status-badge @badgeClass">@r.Status</span>
                                </td>
                            </tr>
                            <tr class="vr-inquiry-row-detail">
                                <td colspan="7">
                                    <div class="vr-inquiry-msg-box">
                                        <div style="font-weight: 700; color: #0f172a; margin-bottom: 4px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.6;">Requirements:</div>
                                        @r.Requirements
                                        @if (!string.IsNullOrWhiteSpace(r.CustomWorkflowNeeds))
                                        {
                                            <div class="vr-inquiry-sub-msg">
                                                <i class="fa-solid fa-diagram-project"></i>
                                                <strong>Workflow Needs:</strong> @r.CustomWorkflowNeeds
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div style="display:flex; justify-content: space-between; align-items: center; padding: 14px 8px 6px;">
            <div class="vr-muted">Page @Model.Page of @Model.TotalPages</div>
            <div style="display:flex; gap: 8px;">
                @if (Model.Page > 1)
                {
                    <a class="vr-sa-btn" href="@Url.Action("EnterpriseInquiries", "SuperAdmin", new { search = Model.Search, status = Model.Status, page = Model.Page - 1, pageSize = Model.PageSize })">Prev</a>
                }
                @if (Model.Page < Model.TotalPages)
                {
                    <a class="vr-sa-btn" href="@Url.Action("EnterpriseInquiries", "SuperAdmin", new { search = Model.Search, status = Model.Status, page = Model.Page + 1, pageSize = Model.PageSize })">Next</a>
                }
            </div>
        </div>
    </section>
</div>

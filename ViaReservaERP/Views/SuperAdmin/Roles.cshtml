@model ViaReservaERP.Models.SuperAdmin.RolesPermissionsViewModel
@{
    ViewData["Title"] = "Roles & Permissions";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Roles</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalRoles</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-user-shield"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">System and custom roles</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Permissions</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalPermissions</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-key"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Available access flags</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Custom Roles Created</div>
                    <div class="vr-sa-report-stat-value">@Model.CustomRolesCreated</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-plus-circle"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Excluding default roles</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Selected Role</div>
                    <div class="vr-sa-report-stat-value">@(Model.Roles.FirstOrDefault(r => r.RoleId == Model.SelectedRoleId)?.RoleName ?? "—")</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #8b5cf6; background: rgba(139, 92, 246, 0.08);"><i class="fa-solid fa-fingerprint"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Access control configuration</div>
        </div>


        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Quick Actions</div>
            <div class="vr-sa-reports-summary-sub">Management & data export</div>
            <div class="vr-sa-reports-summary-actions">
                <button type="button" class="vr-sa-btn vr-sa-btn-primary" data-bs-toggle="modal" data-bs-target="#vrSaRoleCreateModal">
                    <i class="fa-solid fa-plus"></i>
                    <span>Create Role</span>
                </button>

                <div style="width: 1px; height: 28px; background: rgba(15, 23, 42, 0.08); margin: 0 4px;"></div>

                <div class="vr-sa-export-pill">
                    <a class="vr-sa-export-link" title="Export PDF" href="@Url.Action("ExportRolesPermissions", "SuperAdmin", new { format = "pdf", roleId = Model.SelectedRoleId })">
                        <i class="fa-solid fa-file-pdf"></i>
                    </a>
                    <a class="vr-sa-export-link" title="Export CSV" href="@Url.Action("ExportRolesPermissions", "SuperAdmin", new { format = "csv", roleId = Model.SelectedRoleId })">
                        <i class="fa-solid fa-file-csv"></i>
                    </a>
                    <a class="vr-sa-export-link" title="Export Excel" href="@Url.Action("ExportRolesPermissions", "SuperAdmin", new { format = "xlsx", roleId = Model.SelectedRoleId })">
                        <i class="fa-solid fa-file-excel"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <section class="vr-sa-panel vr-sa-reports-filters">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Permission Search</div>
                <div class="vr-sa-panel-sub">Filter the permission matrix by permission name.</div>
            </div>
        </div>
        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-filter-label">Search</div>
                <input class="vr-sa-filter-input" name="permissionSearch" value="@Model.PermissionSearch" placeholder="e.g. Manage Users" />
            </div>
            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply</button>
                    <a class="vr-sa-btn" href="@Url.Action("Roles", "SuperAdmin", new { roleId = Model.SelectedRoleId })">Reset</a>
                </div>
            </div>
        </form>
    </section>

    <div class="vr-sa-reports-grid">
        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">Roles</div>
                    <div class="vr-sa-panel-sub">Select a role to manage permissions.</div>
                </div>
            </div>

            <div class="vr-sa-role-list">
                @foreach (var role in Model.Roles)
                {
                    var isSelected = Model.SelectedRoleId == role.RoleId;
                    <a class="vr-sa-role-item @(isSelected ? "vr-sa-role-item-active" : "")" href="@Url.Action("Roles", "SuperAdmin", new { roleId = role.RoleId, permissionSearch = Model.PermissionSearch })">
                        <div style="font-weight:500;">@role.RoleName</div>
                    </a>
                }
            </div>
        </section>

        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">Permission Matrix</div>
                    <div class="vr-sa-panel-sub">Assign or remove permissions for the selected role.</div>
                </div>
                <div class="vr-sa-pill">@Model.Permissions.Count permissions</div>
            </div>

            @if (!Model.SelectedRoleId.HasValue)
            {
                <div class="vr-sa-alert">
                    <div class="vr-sa-alert-title">No role selected</div>
                    <div class="vr-sa-alert-sub">Select a role to manage its permissions.</div>
                </div>
            }
            else
            {
                <div class="vr-sa-table-wrap vr-sa-table-modern">
                    <table class="vr-sa-table">
                        <thead>
                            <tr>
                                <th>Permission</th>
                                <th style="width: 160px;">Enabled</th>
                                <th style="width: 160px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var perm in Model.Permissions)
                            {
                                var enabled = Model.SelectedRolePermissionIds.Contains(perm.PermissionId);
                                <tr>
                                    <td>
                                        <div style="font-weight:500; color:#0b122d;">@perm.PermissionName</div>
                                    </td>
                                    <td>
                                        @if (enabled)
                                        {
                                            <div class="vr-sa-cell-muted">Enabled</div>
                                        }
                                        else
                                        {
                                            <div class="vr-sa-cell-muted">Disabled</div>
                                        }
                                    </td>
                                    <td>
                                        <form method="post" asp-action="ToggleRolePermission" asp-controller="SuperAdmin">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="roleId" value="@Model.SelectedRoleId" />
                                            <input type="hidden" name="permissionId" value="@perm.PermissionId" />
                                            <input type="hidden" name="enabled" value="@(!enabled)" />
                                            <input type="hidden" name="permissionSearch" value="@Model.PermissionSearch" />
                                            <button type="submit" class="vr-sa-iconbtn" title="@(enabled ? "Remove" : "Assign")" aria-label="@(enabled ? "Remove" : "Assign")">
                                                @if(enabled) { <i class="fa-solid fa-xmark"></i> } else { <i class="fa-solid fa-plus"></i> }
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="vrSaRoleCreateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("CreateRole", "SuperAdmin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <label class="vr-sa-label">Role Name</label>
                    <input name="roleName" class="vr-sa-input" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="vrSaRoleRenameModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Rename Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("RenameRole", "SuperAdmin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roleId" value="@Model.SelectedRoleId" />
                <div class="modal-body">
                    <label class="vr-sa-label">Role Name</label>
                    <input name="roleName" class="vr-sa-input" value="@(Model.Roles.FirstOrDefault(r => r.RoleId == Model.SelectedRoleId)?.RoleName ?? "")" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

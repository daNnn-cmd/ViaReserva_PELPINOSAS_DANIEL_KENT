@model ViaReservaERP.Models.SuperAdmin.SuperAdminDashboardViewModel
@{
    ViewData["Title"] = "Super Admin Dashboard";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

@functions {
    string DeltaClass(double? pct)
    {
        if (!pct.HasValue) return "vr-sa-kpi-delta vr-sa-kpi-delta-na";
        if (pct.Value > 0.0001) return "vr-sa-kpi-delta vr-sa-kpi-delta-up";
        if (pct.Value < -0.0001) return "vr-sa-kpi-delta vr-sa-kpi-delta-down";
        return "vr-sa-kpi-delta";
    }

    string DeltaText(double? pct)
    {
        if (!pct.HasValue) return "—";
        var sign = pct.Value > 0 ? "+" : "";
        return $"{sign}{pct.Value:0.0}%";
    }
}

<div class="vr-sa-reports">
    <div class="vr-sa-grid vr-sa-grid-4" style="margin-bottom: 20px;">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">TOTAL HOTEL COMPANIES</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalHotelCompanies</div>
                    <div class="@DeltaClass(Model.TotalHotelCompaniesDeltaPct)">@DeltaText(Model.TotalHotelCompaniesDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-hotel"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Multi-tenant properties onboarded</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">TOTAL ACTIVE USERS</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalActiveUsers</div>
                    <div class="@DeltaClass(Model.TotalActiveUsersDeltaPct)">@DeltaText(Model.TotalActiveUsersDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #8b5cf6; background: rgba(139, 92, 246, 0.08);"><i class="fa-solid fa-users"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Across all companies</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">TOTAL RESERVATIONS</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalReservations</div>
                    <div class="@DeltaClass(Model.TotalReservationsDeltaPct)">@DeltaText(Model.TotalReservationsDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-calendar-check"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">@Model.SelectedRangeLabel</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">TOTAL REVENUE</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.TotalRevenue.ToString("N0")</div>
                    <div class="@DeltaClass(Model.TotalRevenueDeltaPct)">@DeltaText(Model.TotalRevenueDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #c9a227; background: rgba(201, 162, 39, 0.08);"><i class="fa-solid fa-peso-sign"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Payments captured via Stripe + local</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">ACTIVE SUBSCRIPTIONS</div>
                    <div class="vr-sa-report-stat-value">@Model.ActiveSubscriptions</div>
                    <div class="@DeltaClass(Model.ActiveSubscriptionsDeltaPct)">@DeltaText(Model.ActiveSubscriptionsDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.08);"><i class="fa-solid fa-credit-card"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Renewals due in the next 14 days</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">PENDING SERVICE REQUESTS</div>
                    <div class="vr-sa-report-stat-value">@Model.PendingServiceRequests</div>
                    <div class="@DeltaClass(Model.PendingServiceRequestsDeltaPct)">@DeltaText(Model.PendingServiceRequestsDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-bell-concierge"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Across all properties</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">WORKFLOW PENDING APPROVALS</div>
                    <div class="vr-sa-report-stat-value">@Model.WorkflowPendingApprovals</div>
                    <div class="@DeltaClass(Model.WorkflowPendingApprovalsDeltaPct)">@DeltaText(Model.WorkflowPendingApprovalsDeltaPct) vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #64748b; background: rgba(100, 116, 139, 0.08);"><i class="fa-solid fa-network-wired"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Escalations in the last 24 hours</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">SYSTEM ALERTS</div>
                    <div class="vr-sa-report-stat-value">@Model.SystemAlerts</div>
                    <div class="vr-sa-kpi-delta vr-sa-kpi-delta-na">— vs previous period</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #ef4444; background: rgba(239, 68, 68, 0.08);"><i class="fa-solid fa-triangle-exclamation"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Critical infrastructure health</div>
        </div>
    </div>

    <section class="vr-sa-panel vr-sa-reports-filters" style="margin-bottom:24px;">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Analytics Time Range</div>
                <div class="vr-sa-panel-sub">Selected: <span style="font-weight:500; color:#0b122d;">@Model.SelectedRangeLabel</span></div>
            </div>
        </div>
        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">View by</div>
                <select class="vr-sa-filter-input" name="granularity" onchange="this.form.submit()">
                    <option value="day" selected="@(Model.Granularity == "day")">Day</option>
                    <option value="month" selected="@(Model.Granularity == "month")">Month</option>
                    <option value="year" selected="@(Model.Granularity == "year")">Year</option>
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Start</div>
                <input class="vr-sa-filter-input" type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">End</div>
                <input class="vr-sa-filter-input" type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("Dashboard", "SuperAdmin", new { granularity = Model.Granularity })">Reset</a>
                </div>
            </div>
        </form>
    </section>
</div>



<div class="vr-sa-panels">
    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Revenue Analytics</div>
                <div class="vr-sa-panel-sub">Subscription revenue vs reservation revenue</div>
            </div>
            <div class="vr-sa-pill">@Model.SelectedRangeLabel</div>
        </div>

        <div class="vr-sa-chart vr-sa-chart-compact">
            <div id="vrSaRevenueChart" class="vr-sa-apex"></div>
        </div>
    </section>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Reservation Analytics</div>
                <div class="vr-sa-panel-sub">Bookings, check-ins, check-outs, cancellations</div>
            </div>
            <div class="vr-sa-pill">@Model.SelectedRangeLabel</div>
        </div>

        <div class="vr-sa-chart vr-sa-chart-compact">
            <div id="vrSaReservationChart" class="vr-sa-apex"></div>
        </div>
    </section>
</div>

<div class="vr-sa-panels">
    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Service Analytics</div>
                <div class="vr-sa-panel-sub">Most requested services and request completion</div>
            </div>
            <div class="vr-sa-pill">Operations</div>
        </div>

        <div class="vr-sa-chart vr-sa-chart-compact">
            <div class="vr-sa-chart-split">
                <div>
                    <div class="vr-sa-mini-title">Top Services</div>
                    <div id="vrSaServiceTopChart" class="vr-sa-apex"></div>
                </div>
                <div>
                    <div class="vr-sa-mini-title">Pending vs Completed</div>

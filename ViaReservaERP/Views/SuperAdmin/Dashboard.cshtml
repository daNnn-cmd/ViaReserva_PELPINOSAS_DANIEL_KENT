                </div>
            </div>
        </div>
    </section>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Company Growth Analytics</div>
                <div class="vr-sa-panel-sub">New companies registered and active vs inactive</div>
            </div>
            <div class="vr-sa-pill">@Model.SelectedRangeLabel</div>
        </div>

        <div class="vr-sa-chart vr-sa-chart-compact">
            <div id="vrSaCompanyChart" class="vr-sa-apex"></div>
        </div>
    </section>
</div>

<div class="vr-sa-panels">
    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Workflow Analytics</div>
                <div class="vr-sa-panel-sub">Pending approvals, completed, escalations</div>
            </div>
            <div class="vr-sa-pill">Governance</div>
        </div>

        <div class="vr-sa-chart vr-sa-chart-compact">
            <div id="vrSaWorkflowChart" class="vr-sa-apex"></div>
        </div>
    </section>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Financial Reports</div>
                <div class="vr-sa-panel-sub">Income vs expenses and monthly profit overview</div>
            </div>
            <div class="vr-sa-pill">@Model.SelectedRangeLabel</div>
        </div>

        <div class="vr-sa-chart vr-sa-chart-compact">
            <div id="vrSaFinancialChart" class="vr-sa-apex"></div>
        </div>
    </section>
</div>



@section Scripts {
    @{
        var jsonOpts = new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web);
    }
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.49.1"></script>
    <script>
        (function () {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            const palette = {
                blue: '#1a2a6c',
                burgundy: '#b21f1f',
                text: isDark ? '#e2e8f0' : '#1e293b',
                grid: isDark ? 'rgba(255, 255, 255, 0.06)' : 'rgba(30, 41, 59, 0.10)',
                muted: isDark ? '#94a3b8' : 'rgba(30, 41, 59, 0.62)'
            };

            function baseOptions() {
                return {
                    chart: {
                        toolbar: { show: false },
                        foreColor: palette.muted,
                        fontFamily: 'ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial'
                    },
                    grid: { borderColor: palette.grid, strokeDashArray: 4, padding: { left: 6, right: 6 } },
                    legend: { position: 'bottom', fontWeight: 400, markers: { width: 8, height: 8, radius: 8 }, labels: { colors: palette.muted } },
                    tooltip: { theme: isDark ? 'dark' : 'light' },
                    dataLabels: { enabled: false }
                };
            }

            const revenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueAnalytics, jsonOpts));
            const reservations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReservationAnalytics, jsonOpts));
            const services = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServiceAnalytics, jsonOpts));
            const companies = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CompanyGrowthAnalytics, jsonOpts));
            const workflows = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WorkflowAnalytics, jsonOpts));
            const financial = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FinancialAnalytics, jsonOpts));

            const revenueEl = document.querySelector('#vrSaRevenueChart');
            const reservationEl = document.querySelector('#vrSaReservationChart');
            const serviceTopEl = document.querySelector('#vrSaServiceTopChart');
            const serviceStatusEl = document.querySelector('#vrSaServiceStatusChart');
            const companyEl = document.querySelector('#vrSaCompanyChart');
            const workflowEl = document.querySelector('#vrSaWorkflowChart');
            const financialEl = document.querySelector('#vrSaFinancialChart');

            if (revenueEl) {
                const opt = baseOptions();
                opt.chart.type = 'line';
                opt.chart.height = 210;
                opt.stroke = { curve: 'smooth', width: 2, dashArray: [0, 0, 6, 6] };
                opt.colors = [palette.blue, palette.burgundy];
                opt.series = [
                    { name: 'Subscription Revenue', data: revenue.datasets['Subscription Revenue'] || [] },
                    { name: 'Reservation Revenue', data: revenue.datasets['Reservation Revenue'] || [] },
                    { name: 'Subscription Revenue (Prev)', data: revenue.datasets['Subscription Revenue (Prev)'] || [] },
                    { name: 'Reservation Revenue (Prev)', data: revenue.datasets['Reservation Revenue (Prev)'] || [] }
                ];
                opt.xaxis = { categories: revenue.labels || [], labels: { style: { colors: palette.muted } } };
                opt.yaxis = { labels: { style: { colors: palette.muted } } };
                new ApexCharts(revenueEl, opt).render();
            }

            if (reservationEl) {
                const opt = baseOptions();
                opt.chart.type = 'bar';
                opt.chart.height = 210;
                opt.plotOptions = { bar: { borderRadius: 8, columnWidth: '58%' } };
                opt.series = [
                    { name: 'Bookings', data: reservations.datasets['Bookings'] || [] },
                    { name: 'Check-ins', data: reservations.datasets['Check-ins'] || [] },
                    { name: 'Check-outs', data: reservations.datasets['Check-outs'] || [] },
                    { name: 'Cancellations', data: reservations.datasets['Cancellations'] || [] }
                ];
                opt.colors = [palette.blue, '#0ea5e9', '#64748b', palette.burgundy];
                opt.xaxis = { categories: reservations.labels || [] };
                opt.yaxis = { labels: { style: { colors: palette.muted } } };
                opt.chart.stacked = true;
                new ApexCharts(reservationEl, opt).render();
            }

            if (serviceTopEl) {
                const opt = baseOptions();
                opt.chart.type = 'donut';
                opt.chart.height = 190;
                opt.labels = services.labels || [];
                opt.series = (services.datasets['Most Requested'] || []).map(x => Number(x));
                opt.colors = [palette.blue, palette.burgundy, '#0ea5e9', '#22c55e', '#f59e0b', '#64748b'];
                opt.legend = { position: 'bottom' };
                new ApexCharts(serviceTopEl, opt).render();
            }

            if (serviceStatusEl) {
                const opt = baseOptions();
                opt.chart.type = 'donut';
                opt.chart.height = 190;
                opt.labels = ['Pending', 'Completed'];
                opt.series = (services.datasets['Pending vs Completed'] || []).map(x => Number(x));
                opt.colors = ['#f59e0b', '#22c55e'];
                opt.legend = { position: 'bottom' };
                new ApexCharts(serviceStatusEl, opt).render();
            }

            if (companyEl) {
                const opt = baseOptions();
                opt.chart.type = 'area';
                opt.chart.height = 210;
                opt.stroke = { curve: 'smooth', width: 2 };
                opt.fill = { type: 'solid', opacity: 0.08 };
                opt.colors = [palette.blue, '#0ea5e9', palette.burgundy];
                opt.series = [
                    { name: 'New Companies', data: companies.datasets['New Companies'] || [] },
                    { name: 'Active', data: companies.datasets['Active'] || [] },
                    { name: 'Inactive', data: companies.datasets['Inactive'] || [] }
                ];
                opt.xaxis = { categories: companies.labels || [] };
                new ApexCharts(companyEl, opt).render();
            }

            if (workflowEl) {
                const opt = baseOptions();
                opt.chart.type = 'bar';
                opt.chart.height = 210;
                opt.plotOptions = { bar: { horizontal: true, borderRadius: 8, barHeight: '58%' } };
                opt.series = [
                    { name: 'Count', data: [
                        (workflows.datasets['Pending'] || []).slice(-1)[0] || 0,
                        (workflows.datasets['Completed'] || []).slice(-1)[0] || 0,
                        (workflows.datasets['Escalated'] || []).slice(-1)[0] || 0
                    ] }
                ];
                opt.colors = [palette.blue];
                opt.xaxis = { categories: ['Pending', 'Completed', 'Escalated'], labels: { style: { colors: palette.muted } } };
                new ApexCharts(workflowEl, opt).render();
            }

            if (financialEl) {
                const opt = baseOptions();
                opt.chart.type = 'line';
                opt.chart.height = 210;
                opt.stroke = { curve: 'smooth', width: 2 };
                opt.colors = ['#0ea5e9', palette.burgundy, palette.blue];
                opt.series = [
                    { name: 'Income', data: financial.datasets['Income'] || [] },
                    { name: 'Expenses', data: financial.datasets['Expenses'] || [] },
                    { name: 'Profit', data: financial.datasets['Profit'] || [] }
                ];
                opt.xaxis = { categories: financial.labels || [] };
                new ApexCharts(financialEl, opt).render();
            }
        })();
    </script>
}

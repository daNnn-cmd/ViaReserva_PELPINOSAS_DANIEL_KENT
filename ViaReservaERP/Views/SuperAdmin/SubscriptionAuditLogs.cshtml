@model ViaReservaERP.Models.SuperAdmin.SubscriptionAuditLogsViewModel
@{
    ViewData["Title"] = "Subscription Audit Logs";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Subscription ID</div>
                    <div class="vr-sa-report-stat-value">#@Model.SubscriptionId</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-hashtag"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">System reference</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Company</div>
                    <div class="vr-sa-report-stat-value">@(string.IsNullOrWhiteSpace(Model.CompanyName) ? "—" : Model.CompanyName)</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-hotel"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Tenant scope</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Events</div>
                    <div class="vr-sa-report-stat-value">@Model.Rows.Count</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #8b5cf6; background: rgba(139, 92, 246, 0.08);"><i class="fa-solid fa-history"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Audit trail size</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Last Activity</div>
                    <div class="vr-sa-report-stat-value">@(Model.Rows.OrderByDescending(r => r.TimestampUtc).FirstOrDefault()?.TimestampUtc.ToString("MM-dd HH:mm") ?? "—")</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-clock"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">UTC timeline</div>
        </div>

        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Navigation</div>
            <div class="vr-sa-reports-summary-sub">Subscription drill-down</div>
            <div class="vr-sa-reports-summary-actions">
                <a class="vr-sa-export-btn" href="@Url.Action("SubscriptionDetails", "SuperAdmin", new { id = Model.SubscriptionId })" title="Details">Details</a>
                <a class="vr-sa-export-btn" href="@Url.Action("SubscriptionBillingHistory", "SuperAdmin", new { id = Model.SubscriptionId })" title="Billing History">Billing</a>
                <a class="vr-sa-export-btn" href="@Url.Action("SubscriptionUsageReport", "SuperAdmin", new { id = Model.SubscriptionId })" title="Usage">Usage</a>
                <a class="vr-sa-btn" href="@Url.Action("Subscriptions", "SuperAdmin")"><i class="fa-solid fa-arrow-left"></i></a>
            </div>
        </div>
    </div>

    <section class="vr-sa-panel" style="margin-top:14px;">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Audit Log Master List</div>
                <div class="vr-sa-panel-sub">Most recent subscription-related audit entries for subscription #@Model.SubscriptionId.</div>
            </div>
        </div>

        <div class="vr-sa-table-wrap vr-sa-table-modern" style="margin-top:12px;">
            <table class="vr-sa-table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>User Identity</th>
                        <th>Action Performed</th>
                        <th>Affected Table</th>
                        <th class="text-end">Record ID</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td>
                                <div style="font-size: 0.9rem; color: #0b122d;">@r.TimestampUtc.ToString("MMM dd, yyyy")</div>
                                <div style="font-size: 0.8rem; color: #64748b;">@r.TimestampUtc.ToString("HH:mm:ss")</div>
                            </td>
                            <td>
                                <div style="font-weight: 500; color: #0b122d;">@(string.IsNullOrWhiteSpace(r.UserName) ? "System" : r.UserName)</div>
                            </td>
                            <td>
                                <div class="vr-sa-pill" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; background: rgba(30, 41, 59, 0.05);">@(string.IsNullOrWhiteSpace(r.Action) ? "Unknown" : r.Action)</div>
                            </td>
                            <td class="vr-sa-cell-muted">@(string.IsNullOrWhiteSpace(r.Table) ? "—" : r.Table)</td>
                            <td class="text-end" style="font-family: monospace; font-weight: 500;">@(r.RecordId.HasValue ? $"#{r.RecordId.Value}" : "—")</td>
                            <td class="vr-sa-cell-muted" style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(r.IpAddress) ? "0.0.0.0" : r.IpAddress)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@model ViaReservaERP.Models.SuperAdmin.ReservationMonitoringViewModel
@{
    ViewData["Title"] = "Reservation Management";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Reservations</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalReservations</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-calendar-check"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Across all tenants</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Active Bookings</div>
                    <div class="vr-sa-report-stat-value">@Model.ActiveBookings</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-check-double"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Upcoming & ongoing stays</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">In-House Guests</div>
                    <div class="vr-sa-report-stat-value">@Model.CheckedInGuests</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #8b5cf6; background: rgba(139, 92, 246, 0.08);"><i class="fa-solid fa-suitcase-rolling"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Currently checked-in</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Revenue</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.ReservationRevenue.ToString("N0")</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #c9a227; background: rgba(201, 162, 39, 0.08);"><i class="fa-solid fa-peso-sign"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Captured in range</div>
        </div>


        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Export Options</div>
            <div class="vr-sa-reports-summary-sub">Download current view as PDF, CSV, or XLSX</div>
            <div class="vr-sa-reports-summary-actions">
                <a class="vr-sa-export-btn" title="PDF" href="@Url.Action("Reservations", "SuperAdminReports", new { format = "pdf" })">PDF</a>
                <a class="vr-sa-export-btn" title="CSV" href="@Url.Action("Reservations", "SuperAdminReports", new { format = "csv" })">CSV</a>
                <a class="vr-sa-export-btn" title="Excel" href="@Url.Action("Reservations", "SuperAdminReports", new { format = "xlsx" })">XLSX</a>
            </div>
        </div>
    </div>

    <section class="vr-sa-panel vr-sa-reports-filters">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Filters</div>
                <div class="vr-sa-panel-sub">Narrow down reservation monitoring by date range, granularity, and company.</div>
            </div>
        </div>

        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">View by</div>
                <select class="vr-sa-filter-input" name="granularity" onchange="this.form.submit()">
                    <option value="day" selected="@(Model.Granularity == "day")">Day</option>
                    <option value="month" selected="@(Model.Granularity == "month")">Month</option>
                    <option value="year" selected="@(Model.Granularity == "year")">Year</option>
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Start</div>
                <input class="vr-sa-filter-input" type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">End</div>
                <input class="vr-sa-filter-input" type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Company</div>
                <select class="vr-sa-filter-input" name="companyId">
                    <option value="" selected="@(Model.CompanyId == null)">All companies</option>
                    @foreach (var c in Model.Companies)
                    {
                        <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">@c.CompanyName</option>
                    }
                </select>
            </div>

            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />

            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("Reservations", "SuperAdmin")">Reset</a>
                </div>
            </div>
        </form>
    </section>



    <section class="vr-sa-panel" style="margin-top:14px;">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Reservation Table</div>
                <div class="vr-sa-panel-sub">Read-only monitoring. Use actions to inspect details, payments, service requests, and audit logs.</div>
            </div>
            <div class="vr-sa-pill">Page @Model.Page of @Model.TotalPages</div>
        </div>

        @if (Model.Reservations.Count == 0)
        {
            <div class="vr-sa-alert" style="margin-top:12px;">
                <div class="vr-sa-alert-title">No reservations found</div>
                <div class="vr-sa-alert-sub">Try adjusting date or company filters.</div>
            </div>
        }
        else
        {
            <div class="vr-sa-table-wrap vr-sa-table-modern" style="margin-top:12px;">
                <table class="vr-sa-table">
                    <thead>
                        <tr>
                            <th>Guest</th>
                            <th>Hotel / Company</th>
                            <th>Stay Period</th>
                            <th class="text-center">Payment</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Amount</th>
                            <th style="width: 140px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                        {
                            var payStatus = (r.PaymentStatus ?? "").ToLower();
                            var payClass = payStatus.Contains("succeeded") || payStatus.Contains("paid") ? "vr-sa-status-success" :
                                           payStatus.Contains("failed") ? "vr-sa-status-danger" :
                                           payStatus.Contains("pending") ? "vr-sa-status-warning" : "vr-sa-status-neutral";

                            var resStatus = (r.ReservationStatus ?? "").ToLower();
                            var resClass = resStatus.Contains("confirmed") ? "vr-sa-status-success" :
                                           resStatus.Contains("cancelled") ? "vr-sa-status-danger" :
                                           resStatus.Contains("checked-in") ? "vr-sa-status-info" :
                                           resStatus.Contains("checked-out") ? "vr-sa-status-neutral" : "vr-sa-status-warning";

                            <tr>
                                <td>
                                    <div style="font-weight: 500; color: #0b122d;">@(string.IsNullOrWhiteSpace(r.GuestName) ? "—" : r.GuestName)</div>
                                    <div style="font-size: 0.8rem; color: #64748b;">@(string.IsNullOrWhiteSpace(r.RoomType) ? "—" : r.RoomType)</div>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(r.HotelCompany) ? "—" : r.HotelCompany)</td>
                                <td>
                                    <div style="font-size: 0.9rem; color: #0b122d;">@(r.CheckIn.HasValue ? r.CheckIn.Value.ToString("MMM dd") : "—") - @(r.CheckOut.HasValue ? r.CheckOut.Value.ToString("MMM dd, yyyy") : "—")</div>
                                </td>
                                <td class="text-center">
                                    <div class="vr-sa-cell-muted">@(string.IsNullOrWhiteSpace(r.PaymentStatus) ? "Unknown" : r.PaymentStatus)</div>
                                </td>
                                <td class="text-center">
                                    <div class="vr-sa-cell-muted">@(string.IsNullOrWhiteSpace(r.ReservationStatus) ? "Pending" : r.ReservationStatus)</div>
                                </td>
                                <td class="text-end" style="font-weight: 600; color: #0b122d;">₱ @r.TotalAmount.ToString("N0")</td>
                                <td>
                                    <div class="vr-sa-actions">
                                        <a class="vr-sa-iconbtn" href="@Url.Action("ReservationDetails", "SuperAdmin", new { id = r.ReservationId })" title="Details"><i class="fa-solid fa-eye"></i></a>
                                        <a class="vr-sa-iconbtn" href="@Url.Action("ReservationPayment", "SuperAdmin", new { reservationId = r.ReservationId })" title="Payment"><i class="fa-solid fa-credit-card"></i></a>
                                        <a class="vr-sa-iconbtn" href="@Url.Action("ReservationServiceRequests", "SuperAdmin", new { reservationId = r.ReservationId })" title="Services"><i class="fa-solid fa-bell"></i></a>
                                        <a class="vr-sa-iconbtn" href="@Url.Action("ReservationAuditLogs", "SuperAdmin", new { reservationId = r.ReservationId })" title="Audit Logs"><i class="fa-solid fa-history"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="vr-sa-pagination">
                <div class="vr-sa-cell-muted">Showing @(Math.Min((Model.Page - 1) * Model.PageSize + 1, Model.TotalRows))–@(Math.Min(Model.Page * Model.PageSize, Model.TotalRows)) of @Model.TotalRows</div>
                <div class="vr-sa-pagination-actions">
                    @{
                        var prev = Model.Page - 1;
                        var next = Model.Page + 1;
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("Reservations", "SuperAdmin", new { granularity = Model.Granularity, startDate = Model.StartDate.ToString("yyyy-MM-dd"), endDate = Model.EndDate.ToString("yyyy-MM-dd"), companyId = Model.CompanyId, pageSize = Model.PageSize, page = prev })" aria-disabled="@(Model.Page <= 1)">Previous</a>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <a class="vr-sa-pagebtn @(i == Model.Page ? "vr-sa-pagebtn-active" : "")" href="@Url.Action("Reservations", "SuperAdmin", new { granularity = Model.Granularity, startDate = Model.StartDate.ToString("yyyy-MM-dd"), endDate = Model.EndDate.ToString("yyyy-MM-dd"), companyId = Model.CompanyId, pageSize = Model.PageSize, page = i })">@i</a>
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("Reservations", "SuperAdmin", new { granularity = Model.Granularity, startDate = Model.StartDate.ToString("yyyy-MM-dd"), endDate = Model.EndDate.ToString("yyyy-MM-dd"), companyId = Model.CompanyId, pageSize = Model.PageSize, page = next })" aria-disabled="@(Model.Page >= Model.TotalPages)">Next</a>
                </div>
            </div>
        }
    </section>

    <div class="vr-sa-panels" style="margin-top:14px;">
        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">Reservation Workflow Tracker</div>
                    <div class="vr-sa-panel-sub">Pipeline health for the selected range.</div>
                </div>
            </div>

            <div class="vr-sa-report-grid">
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Booking Created</div><div class="vr-sa-report-sub">Reservations created/active in range</div></div><div class="vr-sa-report-stat-value">@Model.Workflow.BookingCreated</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Payment Processed</div><div class="vr-sa-report-sub">Succeeded payments linked to reservations</div></div><div class="vr-sa-report-stat-value">@Model.Workflow.PaymentProcessed</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Reservation Confirmed</div><div class="vr-sa-report-sub">Status marked as confirmed</div></div><div class="vr-sa-report-stat-value">@Model.Workflow.ReservationConfirmed</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Check-In</div><div class="vr-sa-report-sub">Status marked as checked-in</div></div><div class="vr-sa-report-stat-value">@Model.Workflow.CheckIn</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Check-Out</div><div class="vr-sa-report-sub">Status marked as checked-out/completed</div></div><div class="vr-sa-report-stat-value">@Model.Workflow.CheckOut</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Accounting Recorded</div><div class="vr-sa-report-sub">Transactions referencing reservations</div></div><div class="vr-sa-report-stat-value">@Model.Workflow.AccountingRecorded</div></div>
            </div>
        </section>

        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">Reservation Alerts</div>
                    <div class="vr-sa-panel-sub">Exceptions and issues requiring investigation.</div>
                </div>
            </div>

            <div class="vr-sa-report-grid">
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Overbookings</div><div class="vr-sa-report-sub">Confirmed/pending without room assignment</div></div><div class="vr-sa-report-stat-value">@Model.Alerts.Overbookings</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Failed Payments</div><div class="vr-sa-report-sub">Payments not marked succeeded</div></div><div class="vr-sa-report-stat-value">@Model.Alerts.FailedPayments</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Refund Requests</div><div class="vr-sa-report-sub">Payment status contains refund flag</div></div><div class="vr-sa-report-stat-value">@Model.Alerts.RefundRequests</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Reservation Conflicts</div><div class="vr-sa-report-sub">Missing check-in or check-out dates</div></div><div class="vr-sa-report-stat-value">@Model.Alerts.ReservationConflicts</div></div>
                <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Guest Complaints</div><div class="vr-sa-report-sub">Pending service requests in range</div></div><div class="vr-sa-report-stat-value">@Model.Alerts.GuestComplaints</div></div>
            </div>
        </section>
    </div>

    <section class="vr-sa-panel" style="margin-top:14px;">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Reservation Analytics</div>
                <div class="vr-sa-panel-sub">Trends for reservations, revenue, and cancellations. Respects filters and granularity.</div>
            </div>
        </div>

        <div class="vr-sa-chart-split">
            <div class="vr-sa-chart">
                <div class="vr-sa-mini-title">Reservations (Daily / Monthly / Yearly)</div>
                <div id="vrSaResVolume" class="vr-sa-apex"></div>
            </div>
            <div class="vr-sa-chart">
                <div class="vr-sa-mini-title">Reservation Revenue</div>
                <div id="vrSaResRevenue" class="vr-sa-apex"></div>
            </div>
            <div class="vr-sa-chart">
                <div class="vr-sa-mini-title">Cancellations</div>
                <div id="vrSaResCancel" class="vr-sa-apex"></div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    @{
        var jsonOpts = new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web);
    }
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.49.1"></script>
    <script>
        (function () {
            const palette = {
                blue: '#1a2a6c',
                burgundy: '#b21f1f',
                text: '#1e293b',
                grid: 'rgba(30, 41, 59, 0.10)',
                muted: 'rgba(30, 41, 59, 0.62)'
            };

            function baseOptions() {
                return {
                    chart: {
                        toolbar: { show: false },
                        foreColor: palette.muted,
                        fontFamily: 'ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial'
                    },
                    grid: { borderColor: palette.grid, strokeDashArray: 4, padding: { left: 6, right: 6 } },
                    legend: { position: 'bottom', fontWeight: 400, markers: { width: 8, height: 8, radius: 8 } },
                    tooltip: { theme: 'light' },
                    dataLabels: { enabled: false }
                };
            }

            const volume = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReservationVolumeAnalytics, jsonOpts));
            const revenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueTrendAnalytics, jsonOpts));
            const cancels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CancellationTrendAnalytics, jsonOpts));

            const volumeEl = document.querySelector('#vrSaResVolume');
            const revenueEl = document.querySelector('#vrSaResRevenue');
            const cancelEl = document.querySelector('#vrSaResCancel');

            if (volumeEl) {
                const opt = baseOptions();
                opt.chart.type = 'bar';
                opt.chart.height = 210;
                opt.plotOptions = { bar: { borderRadius: 8, columnWidth: '58%' } };
                opt.series = [
                    { name: 'Reservations', data: volume.datasets['Daily/Monthly/Yearly'] || [] }
                ];
                opt.colors = [palette.blue];
                opt.xaxis = { categories: volume.labels || [] };
                opt.yaxis = { labels: { style: { colors: palette.muted } } };
                new ApexCharts(volumeEl, opt).render();
            }

            if (revenueEl) {
                const opt = baseOptions();
                opt.chart.type = 'line';
                opt.chart.height = 210;
                opt.stroke = { curve: 'smooth', width: 2 };
                opt.series = [
                    { name: 'Reservation Revenue', data: revenue.datasets['Reservation Revenue'] || [] }
                ];
                opt.colors = ['#0ea5e9'];
                opt.xaxis = { categories: revenue.labels || [], labels: { style: { colors: palette.muted } } };
                opt.yaxis = { labels: { style: { colors: palette.muted } } };
                new ApexCharts(revenueEl, opt).render();
            }

            if (cancelEl) {
                const opt = baseOptions();
                opt.chart.type = 'area';
                opt.chart.height = 210;
                opt.stroke = { curve: 'smooth', width: 2 };
                opt.fill = { type: 'solid', opacity: 0.10 };
                opt.series = [
                    { name: 'Cancellations', data: cancels.datasets['Cancellations'] || [] }
                ];
                opt.colors = [palette.burgundy];
                opt.xaxis = { categories: cancels.labels || [] };
                opt.yaxis = { labels: { style: { colors: palette.muted } } };
                new ApexCharts(cancelEl, opt).render();
            }
        })();
    </script>
}
}

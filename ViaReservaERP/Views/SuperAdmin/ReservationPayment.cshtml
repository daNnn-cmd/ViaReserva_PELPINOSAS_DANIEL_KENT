@model ViaReservaERP.Models.SuperAdmin.PaymentDetailsViewModel
@{
    ViewData["Title"] = "Payment Details";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Payment ID</div>
                    <div class="vr-sa-report-stat-value">#@Model.PaymentId</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-hashtag"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">System reference</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Amount Paid</div>
                    <div class="vr-sa-report-stat-value">₱ @Model.AmountPaid.ToString("N0")</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-peso-sign"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Captured total</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Status</div>
                    <div class="vr-sa-report-stat-value">@(string.IsNullOrWhiteSpace(Model.PaymentStatus) ? "—" : Model.PaymentStatus)</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-spinner"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Latest flow state</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Method</div>
                    <div class="vr-sa-report-stat-value">@(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "—" : Model.PaymentMethod)</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #8b5cf6; background: rgba(139, 92, 246, 0.08);"><i class="fa-regular fa-credit-card"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Gateway type</div>
        </div>


        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Navigation</div>
            <div class="vr-sa-reports-summary-sub">Related monitoring contexts</div>
            <div class="vr-sa-reports-summary-actions">
                @if (Model.ReservationId.HasValue)
                {
                    <a class="vr-sa-export-btn" href="@Url.Action("ReservationDetails", "SuperAdmin", new { id = Model.ReservationId.Value })" title="Reservation Details">Details</a>
                    <a class="vr-sa-export-btn" href="@Url.Action("ReservationAuditLogs", "SuperAdmin", new { reservationId = Model.ReservationId.Value })" title="Audit Logs">Audit</a>
                }
                <a class="vr-sa-btn" href="@Url.Action("Reservations", "SuperAdmin")"><i class="fa-solid fa-arrow-left"></i></a>
            </div>
        </div>
    </div>

    <section class="vr-sa-panel vr-sa-reports-filters">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Payment Tracking Overview</div>
                <div class="vr-sa-panel-sub">Stripe references and refund history for payment #@Model.PaymentId.</div>
            </div>
        </div>
    </section>

    @if (Model.PaymentId == 0)
    {
        <section class="vr-sa-panel">
            <div class="vr-sa-panel-head">
                <div>
                    <div class="vr-sa-panel-title">No payment record found</div>
                    <div class="vr-sa-panel-sub">This reservation currently has no linked payments.</div>
                </div>
            </div>
        </section>
    }
    else
    {
        <div class="vr-sa-panels">
            <section class="vr-sa-panel">
                <div class="vr-sa-panel-head">
                    <div>
                        <div class="vr-sa-panel-title">Payment Summary</div>
                        <div class="vr-sa-panel-sub">Identifiers, amount, and state (UTC).</div>
                    </div>
                </div>

                <div class="vr-sa-report-grid">
                    @{
                        var payStatus = (Model.PaymentStatus ?? "").ToLower();
                        var payClass = payStatus.Contains("succeeded") || payStatus.Contains("paid") ? "vr-sa-status-success" :
                                       payStatus.Contains("failed") ? "vr-sa-status-danger" :
                                       payStatus.Contains("pending") ? "vr-sa-status-warning" : "vr-sa-status-neutral";
                    }
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Payment ID</div><div class="vr-sa-report-sub">System reference</div></div><div class="vr-sa-report-stat-value" style="font-weight: 600;">#@Model.PaymentId</div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Reservation ID</div><div class="vr-sa-report-sub">Linked reservation</div></div><div class="vr-sa-report-stat-value">@(Model.ReservationId.HasValue ? "#" + Model.ReservationId.Value.ToString() : "—")</div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Guest Name</div><div class="vr-sa-report-sub">Customer profile</div></div><div class="vr-sa-report-stat-value">@(string.IsNullOrWhiteSpace(Model.GuestName) ? "—" : Model.GuestName)</div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Hotel Company</div><div class="vr-sa-report-sub">Tenant scope</div></div><div class="vr-sa-report-stat-value">@(string.IsNullOrWhiteSpace(Model.HotelCompany) ? "—" : Model.HotelCompany)</div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Payment Method</div><div class="vr-sa-report-sub">Card / bank / local</div></div><div class="vr-sa-report-stat-value">@(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "—" : Model.PaymentMethod)</div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Stripe Reference</div><div class="vr-sa-report-sub">External gateway ID</div></div><div class="vr-sa-report-stat-value"><code style="font-size: 0.85rem; color: #64748b;">@(string.IsNullOrWhiteSpace(Model.StripeReference) ? "—" : Model.StripeReference)</code></div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Payment Status</div><div class="vr-sa-report-sub">Latest flow state</div></div><div class="vr-sa-report-stat-value"><span class="vr-sa-status-pill @payClass">@(string.IsNullOrWhiteSpace(Model.PaymentStatus) ? "—" : Model.PaymentStatus)</span></div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Amount Paid</div><div class="vr-sa-report-sub">Captured total</div></div><div class="vr-sa-report-stat-value" style="font-weight: 700; color: #0b122d;">₱ @Model.AmountPaid.ToString("N0")</div></div>
                    <div class="vr-sa-report-row"><div><div class="vr-sa-report-title">Billing Date</div><div class="vr-sa-report-sub">CreatedAt (UTC)</div></div><div class="vr-sa-report-stat-value">@Model.BillingDateUtc.ToString("yyyy-MM-dd HH:mm")</div></div>
                </div>
            </section>

            <section class="vr-sa-panel">
                <div class="vr-sa-panel-head">
                    <div>
                        <div class="vr-sa-panel-title">Refund History</div>
                        <div class="vr-sa-panel-sub">Derived from audit events flagged as refund.</div>
                    </div>
                </div>

                @if (Model.RefundHistory.Count == 0)
                {
                    <div class="vr-sa-alert" style="margin-top:12px;">
                        <div class="vr-sa-alert-title">No refunds found</div>
                        <div class="vr-sa-alert-sub">No refund-related audit entries exist for this payment.</div>
                    </div>
                }
                else
                {
                    <div class="vr-sa-table-wrap vr-sa-table-modern" style="margin-top:12px;">
                        <table class="vr-sa-table">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>Action</th>
                                    <th>User</th>
                                    <th>Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.RefundHistory)
                                {
                                    <tr>
                                        <td>@r.TimestampUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@(string.IsNullOrWhiteSpace(r.Action) ? "—" : r.Action)</td>
                                        <td>@(string.IsNullOrWhiteSpace(r.Actor) ? "System" : r.Actor)</td>
                                        <td>@(string.IsNullOrWhiteSpace(r.ActorRole) ? "—" : r.ActorRole)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    }
</div>
</div>

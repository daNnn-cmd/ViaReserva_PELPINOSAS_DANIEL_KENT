@model ViaReservaERP.Models.SuperAdmin.CompaniesManagementViewModel
@{
    ViewData["Title"] = "Companies Management";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

@functions {
    private static readonly TimeZoneInfo PhTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Singapore Standard Time");

    string PhTime(DateTime dt)
    {
        var utc = DateTime.SpecifyKind(dt, DateTimeKind.Utc);
        return TimeZoneInfo.ConvertTimeFromUtc(utc, PhTimeZone).ToString("yyyy-MM-dd HH:mm");
    }
}

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Companies</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalCompanies</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-building"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">All non-archived companies</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Active Companies</div>
                    <div class="vr-sa-report-stat-value">@Model.ActiveCompanies</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-house-circle-check"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Operational tenants</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Inactive Companies</div>
                    <div class="vr-sa-report-stat-value">@Model.InactiveCompanies</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #ef4444; background: rgba(239, 68, 68, 0.08);"><i class="fa-solid fa-house-circle-exclamation"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Suspended / inactive</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Expiring Subscriptions</div>
                    <div class="vr-sa-report-stat-value">@Model.ExpiringSubscriptions</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-hourglass-end"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Next 14 days</div>
        </div>


        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Quick Actions</div>
            <div class="vr-sa-reports-summary-sub">Management & data export</div>
            <div class="vr-sa-reports-summary-actions">
                <button type="button" class="vr-sa-btn vr-sa-btn-primary" data-bs-toggle="modal" data-bs-target="#vrSaCompanyCreateModal">
                    <i class="fa-solid fa-plus"></i>
                    <span>Add New</span>
                </button>
                <a class="vr-sa-btn" href="@Url.Action("ArchivedCompanies", "SuperAdmin")" title="View Archives">
                    <i class="fa-solid fa-box-archive"></i>
                    <span>Archives</span>
                </a>
                
                <div style="width: 1px; height: 28px; background: rgba(15, 23, 42, 0.08); margin: 0 4px;"></div>

                <div class="vr-sa-export-pill">
                    <a class="vr-sa-export-link" title="Export PDF" href="@Url.Action("ExportCompanies", "SuperAdmin", new { format = "pdf" })">
                        <i class="fa-solid fa-file-pdf"></i>
                    </a>
                    <a class="vr-sa-export-link" title="Export CSV" href="@Url.Action("ExportCompanies", "SuperAdmin", new { format = "csv" })">
                        <i class="fa-solid fa-file-csv"></i>
                    </a>
                    <a class="vr-sa-export-link" title="Export Excel" href="@Url.Action("ExportCompanies", "SuperAdmin", new { format = "xlsx" })">
                        <i class="fa-solid fa-file-excel"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <section class="vr-sa-panel vr-sa-reports-filters">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Filters</div>
                <div class="vr-sa-panel-sub">Search, filter by subscription status and activation state.</div>
            </div>
        </div>

        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Search</div>
                <input class="vr-sa-filter-input" name="search" value="@Model.Search" placeholder="Company name, email, phone" />
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Subscription Status</div>
                <select class="vr-sa-filter-input" name="subscriptionStatus">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SubscriptionStatus))">All</option>
                    <option value="Active" selected="@(Model.SubscriptionStatus == "Active")">Active</option>
                    <option value="Expired" selected="@(Model.SubscriptionStatus == "Expired")">Expired</option>
                    <option value="Trial" selected="@(Model.SubscriptionStatus == "Trial")">Trial</option>
                    <option value="Cancelled" selected="@(Model.SubscriptionStatus == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Company Status</div>
                <select class="vr-sa-filter-input" name="isActive">
                    <option value="" selected="@(Model.IsActive == null)">All</option>
                    <option value="true" selected="@(Model.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
                </select>
            </div>
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Page Size</div>
                <select class="vr-sa-filter-input" name="pageSize">
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>

            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            <input type="hidden" name="page" value="1" />

            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("Companies", "SuperAdmin")">Reset</a>
                </div>
            </div>
        </form>
    </section>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Company Directory</div>
                <div class="vr-sa-panel-sub">@Model.TotalRows company records found</div>
            </div>
            <div class="vr-sa-pill">Page @Model.Page of @Model.TotalPages</div>
        </div>

        @if (Model.Rows.Count == 0)
        {
            <div class="vr-sa-alert">
                <div class="vr-sa-alert-title">No companies found</div>
                <div class="vr-sa-alert-sub">Try adjusting filters or create a new company tenant.</div>
            </div>
        }
        else
        {
            <div class="vr-sa-table-wrap vr-sa-table-modern">
                <table class="vr-sa-table">
                    <thead>
                        <tr>
                            <th>Company Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th class="vr-sa-cell-center">Subscription Status</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Rows)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:500; color:#0b122d;">@c.CompanyName</div>
                                </td>
                                <td class="vr-sa-cell-muted">@c.Email</td>
                                <td class="vr-sa-cell-muted">@c.Phone</td>
                                 <td class="vr-sa-cell-center">
                                    <div class="vr-sa-cell-muted">@c.SubscriptionStatus</div>
                                </td>
                                <td>
                                    <div class="vr-sa-cell-muted">@(c.IsActive ? "Active" : "Inactive")</div>
                                </td>
                                <td class="vr-sa-cell-muted">@PhTime(c.CreatedAt)</td>
                                <td>
                                    <div class="vr-sa-actions">
                                        <button type="button" class="vr-sa-iconbtn" title="Edit" aria-label="Edit" data-bs-toggle="modal" data-bs-target="#vrSaCompanyEditModal" data-company-id="@c.CompanyId" data-company-name="@c.CompanyName" data-company-email="@c.Email" data-company-phone="@c.Phone" data-company-address="@c.Address" data-company-subscription="@c.SubscriptionStatus" data-company-active="@c.IsActive"><i class="fa-solid fa-pen-to-square"></i></button>

                                        <form method="post" action="@Url.Action("ToggleCompanyActive", "SuperAdmin", new { companyId = c.CompanyId })">
                                            @Html.AntiForgeryToken()
                                            <button class="vr-sa-iconbtn" type="submit" title="@(c.IsActive ? "Suspend" : "Activate")" aria-label="@(c.IsActive ? "Suspend" : "Activate")">
                                                @if(c.IsActive){ <i class="fa-solid fa-pause"></i> } else { <i class="fa-solid fa-play"></i> }
                                            </button>
                                        </form>

                                        <button type="button" class="vr-sa-iconbtn" style="color: #f59e0b;" title="Archive" aria-label="Archive" data-bs-toggle="modal" data-bs-target="#vrSaCompanyArchiveModal" data-company-id="@c.CompanyId" data-company-name="@c.CompanyName"><i class="fa-solid fa-box-archive"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="vr-sa-pagination">
                <div class="vr-sa-cell-muted">Showing @(Math.Min((Model.Page - 1) * Model.PageSize + 1, Model.TotalRows))–@(Math.Min(Model.Page * Model.PageSize, Model.TotalRows)) of @Model.TotalRows</div>
                <div class="vr-sa-pagination-actions">
                    @{
                        var prev = Model.Page - 1;
                        var next = Model.Page + 1;
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("Companies", "SuperAdmin", new { search = Model.Search, subscriptionStatus = Model.SubscriptionStatus, isActive = Model.IsActive, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = prev })" aria-disabled="@(Model.Page <= 1)">Previous</a>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <a class="vr-sa-pagebtn @(i == Model.Page ? "vr-sa-pagebtn-active" : "")" href="@Url.Action("Companies", "SuperAdmin", new { search = Model.Search, subscriptionStatus = Model.SubscriptionStatus, isActive = Model.IsActive, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = i })">@i</a>
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("Companies", "SuperAdmin", new { search = Model.Search, subscriptionStatus = Model.SubscriptionStatus, isActive = Model.IsActive, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = next })" aria-disabled="@(Model.Page >= Model.TotalPages)">Next</a>
                </div>
            </div>
        }
    </section>
</div>

<div class="modal fade vr-sa-modal" id="vrSaCompanyCreateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Company</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("CreateCompany", "SuperAdmin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="vr-sa-label">Company Name</label>
                            <input name="CompanyName" class="vr-sa-input" required maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Subscription Status</label>
                            <input name="SubscriptionStatus" class="vr-sa-input" value="Active" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Email</label>
                            <input name="Email" type="email" class="vr-sa-input" maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Phone</label>
                            <input name="Phone" class="vr-sa-input" maxlength="50" />
                        </div>
                        <div class="col-12">
                            <label class="vr-sa-label">Address</label>
                            <input name="Address" class="vr-sa-input" maxlength="255" />
                        </div>
                        <div class="col-12">
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                                <label class="form-check-label" style="font-weight: 500; color: rgba(15, 23, 42, 0.86);">Active Tenant</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Create Company</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="vrSaCompanyEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Company</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("UpdateCompany", "SuperAdmin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="companyId" id="vrSaCompanyEditId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="vr-sa-label">Company Name</label>
                            <input name="CompanyName" id="vrSaCompanyEditName" class="vr-sa-input" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Subscription Status</label>
                            <input name="SubscriptionStatus" id="vrSaCompanyEditSubscription" class="vr-sa-input" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Email</label>
                            <input name="Email" id="vrSaCompanyEditEmail" class="vr-sa-input" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Phone</label>
                            <input name="Phone" id="vrSaCompanyEditPhone" class="vr-sa-input" />
                        </div>
                        <div class="col-12">
                            <label class="vr-sa-label">Address</label>
                            <input name="Address" id="vrSaCompanyEditAddress" class="vr-sa-input" />
                        </div>
                        <div class="col-12">
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="vrSaCompanyEditActive" />
                                <label class="form-check-label" style="font-weight: 500; color: rgba(15, 23, 42, 0.86);">Active Tenant</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="vrSaCompanyArchiveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Archive Company</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("SoftDeleteCompany", "SuperAdmin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="companyId" id="vrSaCompanyArchiveId" />
                <div class="modal-body">
                    <div style="text-align: center; padding: 20px;">
                        <div style="width: 64px; height: 64px; background: rgba(245, 158, 11, 0.08); color: #f59e0b; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 1.5rem;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                        </div>
                        <h4 style="font-weight: 700; color: #0b122d; margin-bottom: 8px;">Are you sure?</h4>
                        <p style="color: #64748b; font-size: 0.95rem; line-height: 1.5;">You are about to archive <strong id="vrSaCompanyArchiveName" style="color: #0b122d;">this company</strong>. This will suspend all its operations and bookings across the platform.</p>
                    </div>
                </div>
                <div class="modal-footer" style="justify-content: center; gap: 12px; border-top: none; padding-bottom: 30px;">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary" style="background: #f59e0b; border-color: #f59e0b; min-width: 120px;">Yes, Archive</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const modal = document.getElementById('vrSaCompanyEditModal');
            if (!modal) return;

            modal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                if (!btn) return;

                document.getElementById('vrSaCompanyEditId').value = btn.getAttribute('data-company-id') || '';
                document.getElementById('vrSaCompanyEditName').value = btn.getAttribute('data-company-name') || '';
                document.getElementById('vrSaCompanyEditEmail').value = btn.getAttribute('data-company-email') || '';
                document.getElementById('vrSaCompanyEditPhone').value = btn.getAttribute('data-company-phone') || '';
                document.getElementById('vrSaCompanyEditAddress').value = btn.getAttribute('data-company-address') || '';
                document.getElementById('vrSaCompanyEditSubscription').value = btn.getAttribute('data-company-subscription') || '';

                const active = (btn.getAttribute('data-company-active') || '').toLowerCase() === 'true';
                document.getElementById('vrSaCompanyEditActive').checked = active;
            });

            const archiveModal = document.getElementById('vrSaCompanyArchiveModal');
            if (archiveModal) {
                archiveModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    if (!btn) return;
                    document.getElementById('vrSaCompanyArchiveId').value = btn.getAttribute('data-company-id') || '';
                    document.getElementById('vrSaCompanyArchiveName').textContent = btn.getAttribute('data-company-name') || 'this company';
                });
            }
        })();
    </script>
}

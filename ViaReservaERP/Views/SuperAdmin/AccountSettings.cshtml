@{
    Layout = "_SuperAdminLayout";
}

<!-- Appearance & Theme -->
<section class="vr-sa-panel mb-4">
    <div class="vr-sa-panel-head">
        <div>
            <div class="vr-sa-panel-title">Appearance & Theme</div>
            <div class="vr-sa-panel-sub">Customize the look and feel of your console experience</div>
        </div>
    </div>

    <div class="p-4 pt-0 mt-3">
        <div class="d-flex align-items-center justify-content-between p-4" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px;">
            <div class="d-flex align-items-center gap-3">
                <div class="vr-sa-card-icon" style="width: 48px; height: 48px; font-size: 1.1rem; color: #6366f1; background: rgba(99, 102, 241, 0.08);">
                    <i class="fa-solid fa-moon"></i>
                </div>
                <div>
                    <div style="font-weight: 700; font-size: 1rem; color: #0f172a;">Dark Mode</div>
                    <div style="font-size: 0.85rem; color: #64748b; margin-top: 2px;">Switch to a dark interface across all Super Admin pages</div>
                </div>
            </div>
            <button type="button" class="vr-dark-toggle" id="vrDarkModeProfileToggle" aria-label="Toggle dark mode"></button>
        </div>

        <div class="mt-3 d-flex gap-3">
            <div class="flex-grow-1 p-3" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8;">Interface</div>
                <div style="font-weight: 600; color: #0f172a; margin-top: 4px;" id="vrThemeLabel">Light Mode</div>
            </div>
            <div class="flex-grow-1 p-3" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8;">Scope</div>
                <div style="font-weight: 600; color: #0f172a; margin-top: 4px;">All Super Admin Pages</div>
            </div>
            <div class="flex-grow-1 p-3" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8;">Storage</div>
                <div style="font-weight: 600; color: #0f172a; margin-top: 4px;">Browser Local</div>
            </div>
        </div>
    </div>
</section>

<div class="vr-sa-grid" style="grid-template-columns: 1fr 1fr;">
    <div class="vr-sa-card">
        <h3 style="font-size: 1.1rem; font-weight: 600; color: #0b122d; margin-bottom: 20px;">Change Password</h3>
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" style="padding: 10px; font-size: 0.9rem; border-radius: 8px;">
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" style="padding: 10px; font-size: 0.9rem; border-radius: 8px;">
                @TempData["ErrorMessage"]
            </div>
        }

        <form method="post" action="@Url.Action("UpdatePassword", "SuperAdmin")">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="vr-sa-label" style="font-weight: 600;">Current Password</label>
                <input type="password" name="currentPassword" required class="vr-sa-input" />
            </div>
            <div class="mb-3">
                <label class="vr-sa-label" style="font-weight: 600;">New Password</label>
                <input type="password" name="newPassword" required class="vr-sa-input" />
            </div>
            <div class="mb-4">
                <label class="vr-sa-label" style="font-weight: 600;">Confirm New Password</label>
                <input type="password" name="confirmNewPassword" required class="vr-sa-input" />
            </div>
            <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Update Password</button>
        </form>
    </div>

    <div class="vr-sa-card">
        <h3 style="font-size: 1.1rem; font-weight: 600; color: #0b122d; margin-bottom: 20px;">Security & Preferences</h3>
        
        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 16px; border-bottom: 1px solid rgba(15, 23, 42, 0.06); margin-bottom: 16px;">
            <div>
                <div style="font-weight: 600; font-size: 0.95rem; color: #0b122d;">Two-Factor Authentication</div>
                <div style="font-size: 0.85rem; color: rgba(15, 23, 42, 0.62);">Add an extra layer of security to your account.</div>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="tfaSwitch" style="cursor: pointer;">
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 16px; border-bottom: 1px solid rgba(15, 23, 42, 0.06); margin-bottom: 16px;">
            <div>
                <div style="font-weight: 600; font-size: 0.95rem; color: #0b122d;">Email Notifications</div>
                <div style="font-size: 0.85rem; color: rgba(15, 23, 42, 0.62);">Receive alerts about system health and sign-ins.</div>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="emailNotifSwitch" checked style="cursor: pointer;">
            </div>
        </div>
        
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div style="font-weight: 600; font-size: 0.95rem; color: #0b122d;">Session Management</div>
                <div style="font-size: 0.85rem; color: rgba(15, 23, 42, 0.62);">Log out of all other active sessions.</div>
            </div>
            <button type="button" class="vr-sa-btn">Revoke All</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const profileToggle = document.getElementById('vrDarkModeProfileToggle');
            const themeLabel = document.getElementById('vrThemeLabel');
            
            function syncProfileToggle() {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                if (profileToggle) profileToggle.classList.toggle('vr-dark-on', isDark);
                if (themeLabel) themeLabel.textContent = isDark ? 'Dark Mode' : 'Light Mode';
            }
            
            syncProfileToggle();

            if (profileToggle) {
                profileToggle.addEventListener('click', () => {
                    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                    localStorage.setItem('vrSuperAdminTheme', next);
                    const dmBtn = document.getElementById('vrDarkModeToggle');
                    if (dmBtn) dmBtn.click();
                    else {
                        if (next === 'dark') {
                            document.documentElement.setAttribute('data-theme', 'dark');
                        } else {
                            document.documentElement.removeAttribute('data-theme');
                        }
                    }
                    syncProfileToggle();
                });
            }
        })();
    </script>
}

@model List<ViaReservaERP.Models.GuestPortal.ServiceRequestRow>

@foreach (var s in Model)
{
    <tr>
        <td>@s.ServiceName</td>
        <td>₱ @s.Price.ToString("N2")</td>
        <td>@s.Status</td>
        <td class="vr-gp-cell-muted">@s.RequestedAtUtc.ToString("MMM dd, HH:mm")</td>
    </tr>
}

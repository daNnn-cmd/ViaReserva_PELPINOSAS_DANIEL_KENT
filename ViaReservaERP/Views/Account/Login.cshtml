@model ViaReservaERP.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - ViaReserva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: url('/img/login-bg-modern.png') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, rgba(15, 45, 87, 0.85) 0%, rgba(11, 18, 45, 0.95) 100%);
            z-index: 1;
        }

        .login-container {
            position: relative;
            z-index: 2;
            display: flex;
            width: 100%;
            max-width: 1000px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            box-shadow: 0 24px 48px rgba(0,0,0,0.4);
            overflow: hidden;
            animation: fadeIn 0.6s ease-out;
            margin: 24px;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-left {
            flex: 1;
            padding: 48px;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid rgba(255,255,255,0.1);
        }

        .login-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .login-logo {
            height: 40px;
        }

        .login-brand-name {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
        }

        .login-left-content h1 {
            font-size: clamp(1.5rem, 3vw, 2.5rem);
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 16px;
            background: linear-gradient(to right, #fff, #c5a365);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-left-content p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.8);
            line-height: 1.6;
        }

        .login-right {
            width: 450px;
            background: rgba(255,255,255,0.95);
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #0f2d57;
            margin-bottom: 8px;
        }

        .login-subtitle {
            color: #64748b;
            margin-bottom: 32px;
        }

        .form-label {
            font-weight: 600;
            color: #0f2d57;
            font-size: 0.9rem;
        }

        .form-control {
            border-radius: 12px;
            border: 1px solid rgba(15, 45, 87, 0.15);
            padding: 12px 16px;
            font-size: 1rem;
            transition: all 0.2s;
        }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(197, 163, 101, 0.2);
            border-color: #c5a365;
        }

        .vr-btn-primary {
            background: #0f2d57;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            font-size: 1rem;
            color: white;
            transition: all 0.3s;
        }

        .vr-btn-primary:hover {
            background: #1a4278;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(15,45,87,0.2);
        }

        .password-container {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #64748b;
            cursor: pointer;
            padding: 0;
        }

        .password-toggle:hover {
            color: #0f2d57;
        }

        .login-footer {
            margin-top: 24px;
            text-align: center;
            font-size: 0.9rem;
        }

        .login-footer a {
            color: #c5a365;
            text-decoration: none;
            font-weight: 600;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 992px) {
            .login-container {
                flex-direction: column;
                max-width: 450px;
                margin: 16px;
            }
            .login-left {
                padding: 32px;
                border-right: none;
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }
            .login-right {
                width: 100%;
                padding: 32px;
            }
        }

        @@media (max-width: 480px) {
            .login-container {
                border-radius: 18px;
                margin: 12px;
            }
            .login-left {
                padding: 24px;
            }
            .login-right {
                padding: 24px;
            }
            .login-title {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-overlay"></div>
    
    <div class="login-container">
        <div class="login-left">
            <a href="@Url.Action("Index", "Home")" class="login-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" class="login-logo" />
                <span class="login-brand-name">ViaReserva</span>
            </a>
            
            <div class="login-left-content">
                <h1>Elevate Your Hospitality Operations</h1>
                <p>Welcome to the unified workspace for premium hoteliers. Manage reservations, staff workflows, and guest experiences from one secure dashboard.</p>
            </div>
            
            <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">
                &copy; @ViaReservaERP.AppTime.Now.Year ViaReserva Systems. All rights reserved.
            </div>
        </div>
        
        <div class="login-right">
            <h2 class="login-title">Sign In</h2>
            <p class="login-subtitle">Enter your credentials to access your portal.</p>
            
            <form id="vrLoginForm" asp-action="Login" asp-controller="Account" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="mb-4">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="position-relative">
                        <i class="fa-regular fa-envelope position-absolute" style="top: 50%; left: 16px; transform: translateY(-50%); color: #64748b;"></i>
                        <input asp-for="Email" class="form-control" autocomplete="username" inputmode="email" style="padding-left: 44px;" placeholder="Email Address" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label mb-0">Password</label>
                        <a href="@Url.Action("ForgotPassword", "Account")" style="font-size: 0.85rem; color: #c5a365; text-decoration: none; font-weight: 500;">Forgot password?</a>
                    </div>
                    <div class="password-container">
                        <i class="fa-solid fa-lock position-absolute" style="top: 50%; left: 16px; transform: translateY(-50%); color: #64748b;"></i>
                        <input asp-for="Password" id="vrPassword" class="form-control" type="password" autocomplete="current-password" style="padding-left: 44px; padding-right: 44px;" placeholder="••••••••" />
                        <button type="button" id="vrTogglePassword" class="password-toggle" aria-label="Show password">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem; background: #fee2e2; padding: 10px; border-radius: 8px;"></div>

                <button id="vrLoginButton" type="submit" class="btn vr-btn-primary w-100">
                    Sign In
                </button>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Password Toggle
        document.getElementById('vrTogglePassword').addEventListener('click', function () {
            var passwordInput = document.getElementById('vrPassword');
            var icon = this.querySelector('i');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        });
        
        // Form Submission and Lockout Countdown
        const loginBtn = document.getElementById('vrLoginButton');
        const loginForm = document.getElementById('vrLoginForm');
        let lockoutTimer = null;

        function startLockoutCountdown(seconds) {
            let remaining = seconds;
            loginBtn.disabled = true;
            loginBtn.style.opacity = '0.6';
            loginBtn.style.cursor = 'not-allowed';

            lockoutTimer = setInterval(() => {
                remaining--;
                if (remaining <= 0) {
                    clearInterval(lockoutTimer);
                    loginBtn.disabled = false;
                    loginBtn.style.opacity = '1';
                    loginBtn.style.cursor = 'pointer';
                    loginBtn.innerHTML = 'Sign In';
                } else {
                    loginBtn.innerHTML = `<i class="fa-solid fa-clock"></i> Locked (${remaining}s)`;
                }
            }, 1000);
        }

        // Initialize lockout if passed from server
        const initialLockout = @(TempData["LockoutSeconds"] ?? 0);
        if (initialLockout > 0) {
            startLockoutCountdown(initialLockout);
        }

        loginForm.addEventListener('submit', function (e) {
            // Check if form is valid using jQuery validation if available
            if (typeof $ !== 'undefined' && $(loginForm).length > 0) {
                if (!$(loginForm).valid()) {
                    return;
                }
            }
            // Visual state changes ("Signing in...") removed per user request
        });
    </script>
</body>
</html>

@model ViaReservaERP.Models.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["BodyClass"] = "vr-auth-body";
}

<div class="vr-auth-page">
    <section class="vr-auth-left" aria-label="Welcome">
        <div class="vr-auth-left-inner">
            <div class="vr-auth-left-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" class="vr-auth-left-logo" />
                <div class="vr-auth-left-name">ViaReserva</div>
            </div>

            <h1 class="vr-auth-left-title">New Security</h1>
            <p class="vr-auth-left-subtitle">Please choose a strong password that you haven't used elsewhere.</p>
        </div>
    </section>

    <section class="vr-auth-right" aria-label="Reset password">
        <div class="vr-auth-right-inner">
            <div class="vr-auth-card">
                <div class="vr-auth-card-header">
                    <div class="vr-auth-card-kicker">Security</div>
                    <div class="vr-auth-card-title">Set new password</div>
                    <div class="vr-auth-card-subtitle">
                        Finalize your account recovery by setting a new password below.
                    </div>
                </div>

                <form asp-action="ResetPassword" method="post" class="vr-auth-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Token" />

                    <div asp-validation-summary="ModelOnly" class="text-danger vr-validation-summary"></div>

                    <div class="vr-form-group">
                        <label asp-for="Password" class="vr-form-label"></label>
                        <input asp-for="Password" class="vr-form-input" placeholder="New password" required autofocus />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="vr-form-group">
                        <label asp-for="ConfirmPassword" class="vr-form-label"></label>
                        <input asp-for="ConfirmPassword" class="vr-form-input" placeholder="Confirm new password" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="vr-btn vr-btn-primary vr-btn-block vr-auth-submit">
                        <span>Reset Password</span>
                        <i class="fas fa-check"></i>
                    </button>
                </form>

                <div class="vr-auth-meta">
                    <a class="vr-muted-link" href="@Url.Action("Login", "Account")">Back to sign in</a>
                </div>
            </div>
        </div>
    </section>
</div>

@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - ViaReserva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: url('/img/login-bg-modern.png') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, rgba(15, 45, 87, 0.85) 0%, rgba(11, 18, 45, 0.95) 100%);
            z-index: 1;
        }

        .login-container {
            position: relative;
            z-index: 2;
            display: flex;
            width: 1000px;
            max-width: 95%;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-top: 4px solid #c5a365;
            border-radius: 24px;
            box-shadow: 0 24px 48px rgba(0,0,0,0.4);
            overflow: hidden;
            animation: fadeIn 0.6s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-left {
            flex: 1;
            padding: 48px;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid rgba(255,255,255,0.1);
        }

        .login-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .login-logo {
            height: 40px;
        }

        .login-brand-name {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
        }

        .login-left-content h1 {
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 16px;
            background: linear-gradient(to right, #fff, #c5a365);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-left-content p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.8);
            line-height: 1.6;
        }

        .login-right {
            width: 450px;
            background: rgba(255,255,255,0.95);
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-kicker {
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #b91c1c;
            margin-bottom: 8px;
        }

        .login-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #0f2d57;
            margin-bottom: 12px;
        }

        .login-subtitle {
            color: #64748b;
            margin-bottom: 32px;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .form-label {
            font-weight: 600;
            color: #0f2d57;
            font-size: 0.9rem;
        }

        .form-control {
            border-radius: 12px;
            border: 1px solid rgba(15, 45, 87, 0.15);
            padding: 12px 16px;
            font-size: 1rem;
            transition: all 0.2s;
        }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(197, 163, 101, 0.2);
            border-color: #c5a365;
        }

        .vr-btn-gold {
            background: #c5a365;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            font-size: 1rem;
            color: #0f2d57;
            transition: all 0.3s;
        }

        .vr-btn-gold:hover {
            background: #d4b47a;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(197,163,101,0.3);
        }

        .login-footer {
            margin-top: 24px;
            text-align: center;
            font-size: 0.9rem;
        }

        .login-footer a {
            color: #0f2d57;
            text-decoration: none;
            font-weight: 600;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 992px) {
            .login-container {
                flex-direction: column;
                max-width: 450px;
            }
            .login-left {
                padding: 32px;
                border-right: none;
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }
            .login-right {
                width: 100%;
                padding: 32px;
            }
        }
    </style>
</head>
<body>
    <div class="login-overlay"></div>
    
    <div class="login-container">
        <div class="login-left">
            <a href="@Url.Action("Index", "Home")" class="login-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" class="login-logo" />
                <span class="login-brand-name">ViaReserva</span>
            </a>
            
            <div class="login-left-content">
                <h1>Account Recovery</h1>
                <p>If you can’t access your workspace, we’ll help you regain access safely. We prioritize your security and privacy throughout the recovery process.</p>
            </div>
            
            <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">
                &copy; @ViaReservaERP.AppTime.Now.Year ViaReserva Systems. All rights reserved.
            </div>
        </div>
        
        <div class="login-right">
            <div class="login-kicker">Password reset</div>
            <h2 class="login-title">Reset your password</h2>
            <p class="login-subtitle">Enter your email address and we'll send you a link to reset your password.</p>
            
            <form asp-action="ForgotPassword" method="post" novalidate>
                @Html.AntiForgeryToken()
                
                <div class="mb-4">
                    <label for="email" class="form-label">Email Address</label>
                    <div class="position-relative">
                        <i class="fa-regular fa-envelope position-absolute" style="top: 50%; left: 16px; transform: translateY(-50%); color: #64748b;"></i>
                        <input type="email" id="email" name="email" class="form-control" placeholder="Email Address" style="padding-left: 44px;" required autofocus />
                    </div>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem; background: #fee2e2; padding: 10px; border-radius: 8px;"></div>

                <button type="submit" class="btn vr-btn-gold w-100">
                    Send Reset Link
                </button>
            </form>

            <div class="login-footer">
                <a href="@Url.Action("Login", "Account")">Back to sign in</a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>

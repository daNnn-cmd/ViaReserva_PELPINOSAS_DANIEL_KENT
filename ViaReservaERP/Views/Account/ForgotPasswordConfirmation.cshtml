@{
    ViewData["Title"] = "Email Sent";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Sent - ViaReserva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: url('/img/login-bg-modern.png') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, rgba(15, 45, 87, 0.85) 0%, rgba(11, 18, 45, 0.95) 100%);
            z-index: 1;
        }

        .login-container {
            position: relative;
            z-index: 2;
            display: flex;
            width: 1000px;
            max-width: 95%;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-top: 4px solid #c5a365;
            border-radius: 24px;
            box-shadow: 0 24px 48px rgba(0,0,0,0.4);
            overflow: hidden;
            animation: fadeIn 0.6s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-left {
            flex: 1;
            padding: 48px;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid rgba(255,255,255,0.1);
        }

        .login-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .login-logo {
            height: 40px;
        }

        .login-brand-name {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.02em;
        }

        .login-left-content h1 {
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 16px;
            background: linear-gradient(to right, #fff, #c5a365);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-left-content p {
            font-size: 1.1rem;
            color: rgba(255,255,255,0.8);
            line-height: 1.6;
        }

        .login-right {
            width: 450px;
            background: rgba(255,255,255,0.95);
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: left;
        }

        .success-icon-container {
            width: 80px;
            height: 80px;
            background: #f8fafc;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 32px;
        }

        .success-icon-container i {
            font-size: 2.5rem;
            color: #c5a365;
        }

        .login-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #0f2d57;
            margin-bottom: 16px;
        }

        .login-subtitle {
            color: #64748b;
            margin-bottom: 32px;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .vr-btn-primary {
            background: #0f2d57;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            font-size: 1rem;
            color: white;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
            text-align: center;
        }

        .vr-btn-primary:hover {
            background: #1a4278;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(15,45,87,0.2);
            color: white;
        }

        .login-footer {
            margin-top: 24px;
        }

        .login-footer a {
            color: #0d6efd;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.05rem;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 992px) {
            .login-container {
                flex-direction: column;
                max-width: 450px;
            }
            .login-left {
                padding: 32px;
                border-right: none;
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }
            .login-right {
                width: 100%;
                padding: 32px;
            }
        }
    </style>
</head>
<body>
    <div class="login-overlay"></div>
    
    <div class="login-container">
        <div class="login-left">
            <a href="@Url.Action("Index", "Home")" class="login-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" class="login-logo" />
                <span class="login-brand-name">ViaReserva</span>
            </a>
            
            <div class="login-left-content">
                <h1>Check your email</h1>
                <p>We've sent a password reset link to your email address if an account exists. Please follow the instructions in the email to regain access.</p>
            </div>
            
            <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">
                &copy; @ViaReservaERP.AppTime.Now.Year ViaReserva Systems. All rights reserved.
            </div>
        </div>
        
        <div class="login-right">
            <div class="success-icon-container">
                <i class="fa-solid fa-paper-plane"></i>
            </div>
            
            <h2 class="login-title">Link Sent Successfully</h2>
            <p class="login-subtitle">
                Please check your inbox (and spam folder) for a message from ViaReserva. The link will be active for 1 hour.
            </p>
            
            <div class="login-footer">
                <a href="@Url.Action("Login", "Account")">Return to Sign In</a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

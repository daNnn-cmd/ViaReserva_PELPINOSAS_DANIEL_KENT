@model ViaReservaERP.Models.Admin.InventoryViewModel
@{
    ViewData["Title"] = "Room Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <!-- Daily Operations Stats & Quick Actions -->
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Available Now</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalAvailable</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-door-open"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Ready for check-in</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Occupied</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalOccupied</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-person-walking-luggage"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">In-house guests</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Maintenance</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalMaintenance</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #ef4444; background: rgba(239, 68, 68, 0.08);"><i class="fa-solid fa-wrench"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Under maintenance</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Dirty</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalDirty</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #3b82f6; background: rgba(59, 130, 246, 0.08);"><i class="fa-solid fa-broom"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Awaiting housekeeping</div>
        </div>

        @if (User.GetRoleId() == 2)
        {
            <div class="vr-sa-reports-summary">
                <div class="vr-sa-reports-summary-title">Quick Actions</div>
                <div class="vr-sa-reports-summary-sub">Management & data export</div>
                <div class="vr-sa-reports-summary-actions">
                    <button type="button" class="vr-sa-btn vr-sa-btn-primary" data-bs-toggle="modal" data-bs-target="#addRoomModal">Add New Room</button>
                    <div class="d-flex gap-2 mt-1" style="width: 100%; flex-wrap: nowrap;">
                        <button type="button" class="vr-sa-btn" style="background: rgba(15, 23, 42, 0.05); color: #0f172a; border-color: transparent; width: calc(50% - 4px);" data-bs-toggle="modal" data-bs-target="#addRoomTypeModal"><i class="fa-solid fa-layer-group me-1"></i> Types</button>
                        <a class="vr-sa-btn d-flex align-items-center justify-content-center" href="@Url.Action("ArchivedRooms", "Admin")" style="background: rgba(15, 23, 42, 0.05); color: #0f172a; border-color: transparent; width: calc(50% - 4px);"><i class="fa-solid fa-box-archive me-1"></i> Archives</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Filters -->
    <section class="vr-sa-panel vr-sa-reports-filters mb-4">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Filters</div>
                <div class="vr-sa-panel-sub">Search rooms by number.</div>
            </div>
        </div>

        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Search</div>
                <input class="vr-sa-filter-input" name="search" value="@Model.Search" placeholder="Room number" />
            </div>

            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            <input type="hidden" name="page" value="1" />

            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("Rooms", "Admin")">Reset</a>
                </div>
            </div>
        </form>
    </section>

    <section class="vr-sa-panel mb-4">
        <div class="vr-sa-panel-head">
            <div class="vr-sa-panel-title">Inventory Master List</div>
        </div>

        @if (Model.Rows == null || !Model.Rows.Any())
        {
            <div class="p-5 text-center vr-sa-cell-muted">No rooms found.</div>
        }
        else
        {
            <div class="vr-sa-table-wrap vr-sa-table-modern">
                <table class="vr-sa-table">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Room #</th>
                            <th>Type</th>
                            <th>Price / Night</th>
                            <th>Current Occupant</th>
                            <th class="vr-sa-cell-center">Status</th>
                            <th style="width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            var room = row.Room;
                            <tr>
                                <td style="font-weight: 700; color: #1e293b;">@room.RoomNumber</td>
                                <td class="vr-sa-cell-main">@(room.RoomType?.TypeName ?? "Standard")</td>
                                <td class="vr-sa-cell-main">₱ @(room.RoomType?.BasePrice?.ToString("N2") ?? "0.00")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(row.CurrentOccupant))
                                    {
                                        <div style="font-weight: 600; color: #0b122d;">@row.CurrentOccupant</div>
                                        <div style="font-size: 0.75rem; color: #64748b;">Res #@row.CurrentReservationId</div>
                                    }
                                    else
                                    {
                                        <span class="vr-sa-cell-muted">No occupant</span>
                                    }
                                </td>
                                <td class="vr-sa-cell-center">
                                    <div style="font-weight: 500; color: #475569;">@room.Status</div>
                                </td>
                                <td>
                                    <div class="vr-sa-actions">
                                    @if (User.GetRoleId() == 2)
                                    {
                                        <button type="button" class="vr-sa-iconbtn" title="Edit" data-bs-toggle="modal" data-bs-target="#editRoomModal"
                                                data-room-id="@row.Room.RoomId"
                                                data-room-number="@row.Room.RoomNumber"
                                                data-room-type-id="@row.Room.RoomTypeId"
                                                data-room-status="@row.Room.Status">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>

                                        <button type="button" class="vr-sa-iconbtn" style="color: #f59e0b;" title="Archive" 
                                                data-bs-toggle="modal" data-bs-target="#archiveRoomModal" 
                                                data-room-id="@row.Room.RoomId" data-room-number="@row.Room.RoomNumber">
                                            <i class="fa-solid fa-box-archive"></i>
                                        </button>
                                    }

                                        <form method="post" action="@Url.Action("UpdateRoomStatus", "Admin", new { id = room.RoomId })">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="status" value="Maintenance" />
                                            <button type="submit" class="vr-sa-iconbtn" style="color:#ef4444;" title="Set Maintenance"><i class="fa-solid fa-hammer"></i></button>
                                        </form>

                                        <form method="post" action="@Url.Action("UpdateRoomStatus", "Admin", new { id = room.RoomId })">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="status" value="Dirty" />
                                            <button type="submit" class="vr-sa-iconbtn" style="color:#3b82f6;" title="Mark Dirty"><i class="fa-solid fa-broom"></i></button>
                                        </form>

                                        <form method="post" action="@Url.Action("UpdateRoomStatus", "Admin", new { id = room.RoomId })">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="status" value="Available" />
                                            <button type="submit" class="vr-sa-iconbtn" style="color:#22c55e;" title="Set Available"><i class="fa-solid fa-circle-check"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="vr-sa-pagination">
                <div class="vr-sa-cell-muted">Showing @(Math.Min((Model.Page - 1) * Model.PageSize + 1, Model.TotalRows))–@(Math.Min(Model.Page * Model.PageSize, Model.TotalRows)) of @Model.TotalRows</div>
                <div class="vr-sa-pagination-actions">
                    @{
                        var prev = Model.Page - 1;
                        var next = Model.Page + 1;
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("Rooms", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = prev })" aria-disabled="@(Model.Page <= 1)">Previous</a>
                    
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        if (Model.TotalPages > 8 && i > 3 && i < Model.TotalPages - 2 && Math.Abs(i - Model.Page) > 1)
                        {
                            if (i == 4 || i == Model.TotalPages - 3) { <span class="vr-sa-cell-muted px-2">...</span> }
                            continue;
                        }
                        <a class="vr-sa-pagebtn @(i == Model.Page ? "vr-sa-pagebtn-active" : "")" href="@Url.Action("Rooms", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = i })">@i</a>
                    }

                    <a class="vr-sa-pagebtn" href="@Url.Action("Rooms", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = next })" aria-disabled="@(Model.Page >= Model.TotalPages)">Next</a>
                </div>
            </div>
        }
    </section>
</div>

<div class="modal fade vr-sa-modal" id="addRoomModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Room</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("CreateRoom", "Admin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="vr-sa-label">Room Number</label>
                            <input type="text" name="RoomNumber" class="vr-sa-input" placeholder="e.g. 101" required maxlength="20" />
                        </div>
                        <div class="col-12">
                            <label class="vr-sa-label">Room Type</label>
                            <select name="RoomTypeId" class="vr-sa-input" required>
                                @foreach(var t in Model.RoomTypes) {
                                    <option value="@t.RoomTypeId">@t.TypeName</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Create Room</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="addRoomTypeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Room Type</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("CreateRoomType", "Admin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="vr-sa-label">Type Name</label>
                            <input type="text" name="typeName" class="vr-sa-input" placeholder="e.g. Deluxe" required />
                        </div>
                        <div class="col-12">
                            <label class="vr-sa-label">Base Price / Night</label>
                            <input type="number" name="basePrice" step="0.01" class="vr-sa-input" placeholder="e.g. 2500" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Create Type</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="editRoomModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Room</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("UpdateRoom", "Admin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roomId" id="vrEditRoomId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="vr-sa-label">Room Number</label>
                            <input type="text" name="roomNumber" id="vrEditRoomNumber" class="vr-sa-input" required />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Room Type</label>
                            <select name="roomTypeId" id="vrEditRoomTypeId" class="vr-sa-input" required>
                                @foreach (var t in Model.RoomTypes)
                                {
                                    <option value="@t.RoomTypeId">@t.TypeName</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="vr-sa-label">Status</label>
                            <select name="status" id="vrEditRoomStatus" class="vr-sa-input" required>
                                <option value="Available">Available</option>
                                <option value="Occupied">Occupied</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Dirty">Dirty</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>



<div class="modal fade vr-sa-modal" id="archiveRoomModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Archive Room</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("DeleteRoom", "Admin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="vrArchiveRoomId" />
                <div class="modal-body">
                    <div class="text-center p-4">
                        <div style="width: 64px; height: 64px; background: rgba(245, 158, 11, 0.08); color: #f59e0b; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 1.5rem;">
                            <i class="fa-solid fa-box-archive"></i>
                        </div>
                        <h4 style="font-weight: 700; color: #0b122d; margin-bottom: 8px;">Archive this room?</h4>
                        <p style="color: #64748b; font-size: 0.95rem; line-height: 1.5;">You are about to archive Room <strong id="vrArchiveRoomNumber" style="color: #0b122d;">#</strong>. This will remove it from the active inventory list.</p>
                    </div>
                </div>
                <div class="modal-footer" style="justify-content: center; border-top: none; padding-bottom: 30px;">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary" style="background: #f59e0b; border-color: #f59e0b; min-width: 120px;">Confirm Archive</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const editModal = document.getElementById('editRoomModal');
            editModal?.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                if (!btn) return;

                document.getElementById('vrEditRoomId').value = btn.getAttribute('data-room-id') || '';
                document.getElementById('vrEditRoomNumber').value = btn.getAttribute('data-room-number') || '';
                const typeId = btn.getAttribute('data-room-type-id') || '';
                const typeSelect = document.getElementById('vrEditRoomTypeId');
                if (typeSelect) typeSelect.value = typeId;

                const status = btn.getAttribute('data-room-status') || '';
                const statusSelect = document.getElementById('vrEditRoomStatus');
                if (statusSelect) statusSelect.value = status;
            });

            const archiveModal = document.getElementById('archiveRoomModal');
            if (archiveModal) {
                archiveModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    if (!btn) return;
                    document.getElementById('vrArchiveRoomId').value = btn.getAttribute('data-room-id') || '';
                    document.getElementById('vrArchiveRoomNumber').textContent = btn.getAttribute('data-room-number') || '#';
                });
            }
        })();
    </script>
}

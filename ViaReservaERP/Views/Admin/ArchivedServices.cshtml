@model ViaReservaERP.Models.Admin.ServiceManagementViewModel
@{
    ViewData["Title"] = "Archived Services";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <div class="vr-sa-reports-stats" style="grid-template-columns: 1fr auto;">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Archived Services</div>
                    <div class="vr-sa-report-stat-value">@Model.CatalogTotalRows</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-box-archive"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Services that have been decommissioned or archived</div>
        </div>

        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Navigation</div>
            <div class="vr-sa-reports-summary-sub">Return to service management</div>
            <div class="vr-sa-reports-summary-actions">
                <a class="vr-sa-btn vr-sa-btn-primary" href="@Url.Action("Services", "Admin")"><i class="fa-solid fa-arrow-left me-1"></i> Back to Services</a>
            </div>
        </div>
    </div>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Archived Service Catalog List</div>
                <div class="vr-sa-panel-sub">Records here are hidden from active selection and management until restored.</div>
            </div>
            <div class="vr-sa-pill">Page @Model.CatalogPage of @Math.Max(1, Model.CatalogTotalPages)</div>
        </div>

        @if (Model.CatalogRows.Count == 0)
        {
            <div class="vr-sa-alert">
                <div class="vr-sa-alert-title">No archived services</div>
                <div class="vr-sa-alert-sub">Archived service records will appear here for restoration.</div>
            </div>
        }
        else
        {
            <div class="vr-sa-table-wrap vr-sa-table-modern">
                <table class="vr-sa-table">
                    <thead>
                        <tr>
                            <th>Service Name</th>
                            <th>Price</th>
                            <th class="vr-sa-cell-center">Status</th>
                            <th style="width: 100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var svc in Model.CatalogRows)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 700; color: #0b122d;">@svc.ServiceName</div>
                                </td>
                                <td>
                                    <div class="vr-sa-cell-muted">₱ @((svc.Price ?? 0m).ToString("N2"))</div>
                                </td>
                                <td class="vr-sa-cell-center">
                                    <div class="vr-sa-pill" style="background: rgba(100, 116, 139, 0.1); color: #64748b;">Archived</div>
                                </td>
                                <td>
                                    <div class="vr-sa-actions">
                                        <button type="button" class="vr-sa-iconbtn" style="color: #22c55e;" title="Restore" aria-label="Restore" 
                                                data-bs-toggle="modal" data-bs-target="#restoreServiceModal" 
                                                data-service-id="@svc.ServiceId" data-service-name="@svc.ServiceName">
                                            <i class="fa-solid fa-rotate-left"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="vr-sa-pagination">
                <div class="vr-sa-cell-muted">Showing @(Math.Min((Model.CatalogPage - 1) * Model.CatalogPageSize + 1, Model.CatalogTotalRows))–@(Math.Min(Model.CatalogPage * Model.CatalogPageSize, Model.CatalogTotalRows)) of @Model.CatalogTotalRows</div>
                <div class="vr-sa-pagination-actions">
                    @{
                        var prev = Model.CatalogPage - 1;
                        var next = Model.CatalogPage + 1;
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("ArchivedServices", "Admin", new { search = Model.Search, cPage = prev })" aria-disabled="@(Model.CatalogPage <= 1)">Previous</a>
                    @for (var i = 1; i <= Math.Max(1, Model.CatalogTotalPages); i++)
                    {
                        <a class="vr-sa-pagebtn @(i == Model.CatalogPage ? "vr-sa-pagebtn-active" : "")" href="@Url.Action("ArchivedServices", "Admin", new { search = Model.Search, cPage = i })">@i</a>
                    }
                    <a class="vr-sa-pagebtn" href="@Url.Action("ArchivedServices", "Admin", new { search = Model.Search, cPage = next })" aria-disabled="@(Model.CatalogPage >= Math.Max(1, Model.CatalogTotalPages))">Next</a>
                </div>
            </div>
        }
    </section>
</div>

<div class="modal fade vr-sa-modal" id="restoreServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Restore Service</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("RestoreService", "Admin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="vrRestoreServiceId" />
                <div class="modal-body">
                    <div style="text-align: center; padding: 20px;">
                        <div style="width: 64px; height: 64px; background: rgba(34, 197, 94, 0.08); color: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 1.5rem;">
                            <i class="fa-solid fa-rotate-left"></i>
                        </div>
                        <h4 style="font-weight: 700; color: #0b122d; margin-bottom: 8px;">Restore Service?</h4>
                        <p style="color: #64748b; font-size: 0.95rem; line-height: 1.5;">You are about to restore service <strong id="vrRestoreServiceName" style="color: #0b122d;">#</strong>. This will return it to the active catalog list.</p>
                    </div>
                </div>
                <div class="modal-footer" style="justify-content: center; gap: 12px; border-top: none; padding-bottom: 30px;">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary" style="background: #22c55e; border-color: #22c55e; min-width: 120px;">Yes, Restore</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const restoreModal = document.getElementById('restoreServiceModal');
            if (restoreModal) {
                restoreModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    if (!btn) return;
                    document.getElementById('vrRestoreServiceId').value = btn.getAttribute('data-service-id') || '';
                    document.getElementById('vrRestoreServiceName').textContent = btn.getAttribute('data-service-name') || '#';
                });
            }
        })();
    </script>
}

@model ViaReservaERP.Models.Admin.GuestsViewModel
@{
    ViewData["Title"] = "Guest Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <!-- Quick Stats & Actions -->
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Guests</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalGuests</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #6366f1; background: rgba(99, 102, 241, 0.08);"><i class="fa-solid fa-users"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Lifetime database</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Active Accounts</div>
                    <div class="vr-sa-report-stat-value">@Model.ActiveGuests</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-user-check"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Verified guests</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Inactive</div>
                    <div class="vr-sa-report-stat-value">@Model.InactiveGuests</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #64748b; background: rgba(100, 116, 139, 0.08);"><i class="fa-solid fa-user-slash"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Suspended or pending</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">New This Month</div>
                    <div class="vr-sa-report-stat-value">@Model.NewGuestsThisMonth</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-user-plus"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Growth vs last month</div>
        </div>

        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Quick Actions</div>
            <form method="get" action="@Url.Action("Guests", "Admin")">
                <input type="text" name="search" class="vr-sa-input mb-2" style="font-size: 0.85rem;" placeholder="Search name, email..." value="@Model.Search" />
                <div class="vr-sa-reports-summary-actions">
                    <button type="submit" class="vr-sa-btn mb-1">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <span>Search</span>
                    </button>


                    <div class="vr-sa-export-pill">
                        <a class="vr-sa-export-link" title="Export PDF" href="@Url.Action("ExportGuests", "AdminReports", new { format = "pdf" })">
                            <i class="fa-solid fa-file-pdf"></i>
                        </a>
                        <a class="vr-sa-export-link" title="Export CSV" href="@Url.Action("ExportGuests", "AdminReports", new { format = "csv" })">
                            <i class="fa-solid fa-file-csv"></i>
                        </a>
                        <a class="vr-sa-export-link" title="Export Excel" href="@Url.Action("ExportGuests", "AdminReports", new { format = "xlsx" })">
                            <i class="fa-solid fa-file-excel"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div class="vr-sa-panel-title">Guest Directory</div>
        </div>

        <div class="vr-sa-table-wrap vr-sa-table-modern">
            <table class="vr-sa-table">
                <thead>
                    <tr>
                        <th>Guest Details</th>
                        <th>Contact Info</th>
                        <th class="vr-sa-cell-center">Status</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.Rows)
                    {
                        <tr>
                            <td>
                                <div style="font-weight: 700; color: #0f172a;">@g.FullName</div>
                                <div class="vr-sa-cell-muted" style="font-size: 0.82rem;">Registered: @g.CreatedAt.ToShortDateString()</div>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #475569;">
                                        <i class="fa-regular fa-envelope" style="width: 14px; opacity: 0.6;"></i> @(string.IsNullOrEmpty(g.Email) ? "No Email" : g.Email)
                                    </div>
                                    <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #475569;">
                                        <i class="fa-solid fa-phone" style="width: 14px; opacity: 0.6;"></i> @(string.IsNullOrEmpty(g.Phone) ? "No Phone" : g.Phone)
                                    </div>
                                </div>
                            </td>
                            <td class="vr-sa-cell-center">
                                <div style="font-weight: 500; color: @(g.IsActive ? "#22c55e" : "#64748b");">
                                    @(g.IsActive ? "Active" : "Inactive")
                                </div>
                            </td>
                            <td>
                                <div class="vr-sa-actions">
                                    <a class="vr-sa-iconbtn" title="View Profile" href="@Url.Action("GuestDetails", "Admin", new { id = g.GuestId })">
                                        <i class="fa-solid fa-address-card"></i>
                                    </a>
                                    @if (User.GetRoleId() == 2)
                                    {
                                        <form method="post" action="@Url.Action("ToggleGuestActive", "Admin", new { id = g.GuestId })" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="vr-sa-iconbtn" title="@(g.IsActive ? "Deactivate" : "Activate")" style="color: @(g.IsActive ? "#f59e0b" : "#22c55e");">
                                                <i class="fa-solid @(g.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="vr-sa-pagination">
            <div class="vr-sa-cell-muted">Showing @(Math.Min((Model.Page - 1) * Model.PageSize + 1, Model.TotalRows))–@(Math.Min(Model.Page * Model.PageSize, Model.TotalRows)) of @Model.TotalRows</div>
            <div class="vr-sa-pagination-actions">
                @{
                    var prev = Model.Page - 1;
                    var next = Model.Page + 1;
                }
                <a class="vr-sa-pagebtn" href="@Url.Action("Guests", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = prev })" aria-disabled="@(Model.Page <= 1)">Previous</a>
                
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    if (Model.TotalPages > 8 && i > 3 && i < Model.TotalPages - 2 && Math.Abs(i - Model.Page) > 1)
                    {
                        if (i == 4 || i == Model.TotalPages - 3) { <span class="vr-sa-cell-muted px-2">...</span> }
                        continue;
                    }
                    <a class="vr-sa-pagebtn @(i == Model.Page ? "vr-sa-pagebtn-active" : "")" href="@Url.Action("Guests", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = i })">@i</a>
                }

                <a class="vr-sa-pagebtn" href="@Url.Action("Guests", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = next })" aria-disabled="@(Model.Page >= Model.TotalPages)">Next</a>
            </div>
        </div>
    </section>
</div>

<div class="modal fade vr-sa-modal" id="addGuestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Guest</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("CreateGuest", "Admin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="vr-sa-label">Full Name</label>
                            <input type="text" name="FullName" class="vr-sa-input" placeholder="e.g. John Doe" required maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Email (Optional)</label>
                            <input type="email" name="Email" class="vr-sa-input" placeholder="john@example.com" maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Phone (Optional)</label>
                            <input type="text" name="Phone" class="vr-sa-input" placeholder="+63..." maxlength="50" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Create Guest</button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

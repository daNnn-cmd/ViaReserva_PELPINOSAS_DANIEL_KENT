@model ViaReservaERP.Models.Admin.StaffManagementViewModel
@{
    ViewData["Title"] = "Staff Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="vr-sa-reports">
    <!-- Quick Stats & Actions -->
    <div class="vr-sa-reports-stats">
        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Total Staff</div>
                    <div class="vr-sa-report-stat-value">@Model.TotalStaff</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #6366f1; background: rgba(99, 102, 241, 0.08);"><i class="fa-solid fa-users-gear"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Authorized users</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Authorized</div>
                    <div class="vr-sa-report-stat-value">@Model.ActiveStaff</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #22c55e; background: rgba(34, 197, 94, 0.08);"><i class="fa-solid fa-user-shield"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Active access</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">Revoked</div>
                    <div class="vr-sa-report-stat-value">@Model.RevokedStaff</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #ef4444; background: rgba(239, 68, 68, 0.08);"><i class="fa-solid fa-user-lock"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Disabled accounts</div>
        </div>

        <div class="vr-sa-report-stat">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div class="vr-sa-report-stat-kicker" style="font-weight: 800; color: #0b122d;">New Members</div>
                    <div class="vr-sa-report-stat-value">@Model.NewStaffThisMonth</div>
                </div>
                <div class="vr-sa-card-icon" style="color: #f59e0b; background: rgba(245, 158, 11, 0.08);"><i class="fa-solid fa-user-plus"></i></div>
            </div>
            <div class="vr-sa-report-stat-sub" style="margin-top: 14px;">Added this month</div>
        </div>

        <div class="vr-sa-reports-summary">
            <div class="vr-sa-reports-summary-title">Quick Actions</div>
            <div class="vr-sa-reports-summary-sub">Management & data export</div>
            <div class="vr-sa-reports-summary-actions">
                <button type="button" class="vr-sa-btn vr-sa-btn-primary" data-bs-toggle="modal" data-bs-target="#addStaffModal">
                    <i class="fa-solid fa-plus"></i>
                    <span>Add New</span>
                </button>
                <a class="vr-sa-btn" href="@Url.Action("ArchivedStaff", "Admin")" title="View Archives">
                    <i class="fa-solid fa-box-archive"></i>
                    <span>Archives</span>
                </a>

                <div style="width: 1px; height: 28px; background: rgba(15, 23, 42, 0.08); margin: 0 4px;"></div>

                <div class="vr-sa-export-pill">
                    <a class="vr-sa-export-link" title="Export PDF" href="@Url.Action("ExportStaff", "AdminReports", new { format = "pdf" })">
                        <i class="fa-solid fa-file-pdf"></i>
                    </a>
                    <a class="vr-sa-export-link" title="Export CSV" href="@Url.Action("ExportStaff", "AdminReports", new { format = "csv" })">
                        <i class="fa-solid fa-file-csv"></i>
                    </a>
                    <a class="vr-sa-export-link" title="Export Excel" href="@Url.Action("ExportStaff", "AdminReports", new { format = "xlsx" })">
                        <i class="fa-solid fa-file-excel"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <section class="vr-sa-panel vr-sa-reports-filters mb-4">
        <div class="vr-sa-panel-head">
            <div>
                <div class="vr-sa-panel-title">Filters</div>
                <div class="vr-sa-panel-sub">Search staff by name or email.</div>
            </div>
        </div>

        <form method="get" class="vr-sa-filter-grid">
            <div class="vr-sa-filter">
                <div class="vr-sa-filter-label">Search</div>
                <input class="vr-sa-filter-input" name="search" value="@Model.Search" placeholder="Name or email" />
            </div>

            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            <input type="hidden" name="page" value="1" />

            <div class="vr-sa-filter" style="grid-column: 1 / -1;">
                <div class="vr-sa-report-card-actions">
                    <button type="submit" class="vr-sa-btn">Apply Filters</button>
                    <a class="vr-sa-btn" href="@Url.Action("Staff", "Admin")">Reset</a>
                </div>
            </div>
        </form>
    </section>

    <section class="vr-sa-panel">
        <div class="vr-sa-panel-head">
            <div class="vr-sa-panel-title">Staff Directory</div>
        </div>

        <div class="vr-sa-table-wrap vr-sa-table-modern">
            <table class="vr-sa-table">
                <thead>
                    <tr>
                        <th>Staff Member</th>
                        <th>Role & Access</th>
                        <th class="vr-sa-cell-center">Created At</th>
                        <th class="vr-sa-cell-center">Status</th>
                        <th style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Rows)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="vr-sa-card-icon" style="width: 38px; height: 38px; font-size: 0.9rem; color: #64748b; background: #f1f5f9; flex-shrink: 0;">
                                        <i class="fa-solid fa-user"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight: 700; color: #0f172a;">@u.FullName</div>
                                        <div class="vr-sa-cell-muted" style="font-size: 0.82rem;">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @(u.Role?.RoleName ?? "No Role")
                            </td>
                            <td class="vr-sa-cell-muted vr-sa-cell-center">
                                @u.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td class="vr-sa-cell-center">
                                <div style="font-weight: 500; color: @(u.IsActive ? "#22c55e" : "#64748b");">
                                    @(u.IsActive ? "Authorized" : "Revoked")
                                </div>
                            </td>
                            <td>
                                <div class="vr-sa-actions">
                                    <button type="button" class="vr-sa-iconbtn" title="Edit" data-bs-toggle="modal" data-bs-target="#editStaffModal"
                                            data-staff-id="@u.UserId" data-staff-name="@u.FullName" data-staff-role="@u.RoleId" data-staff-active="@u.IsActive">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <form method="post" action="@Url.Action("ToggleStaffActive", "Admin", new { id = u.UserId })" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="vr-sa-btn" style="min-width: 110px; font-size: 0.8rem;">
                                            <i class="fa-solid @(u.IsActive ? "fa-user-lock" : "fa-user-check") me-2"></i>
                                            @(u.IsActive ? "Disable" : "Enable")
                                        </button>
                                    </form>
                                    <button type="button" class="vr-sa-iconbtn" style="color: #f59e0b;" title="Archive" 
                                            data-bs-toggle="modal" data-bs-target="#archiveStaffModal" 
                                            data-staff-id="@u.UserId" data-staff-name="@u.FullName">
                                        <i class="fa-solid fa-box-archive"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="vr-sa-pagination">
            <div class="vr-sa-cell-muted">Showing @(Math.Min((Model.Page - 1) * Model.PageSize + 1, Model.TotalRows))–@(Math.Min(Model.Page * Model.PageSize, Model.TotalRows)) of @Model.TotalRows</div>
            <div class="vr-sa-pagination-actions">
                @{
                    var prev = Model.Page - 1;
                    var next = Model.Page + 1;
                }
                <a class="vr-sa-pagebtn" href="@Url.Action("Staff", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = prev })" aria-disabled="@(Model.Page <= 1)">Previous</a>
                
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    if (Model.TotalPages > 8 && i > 3 && i < Model.TotalPages - 2 && Math.Abs(i - Model.Page) > 1)
                    {
                        if (i == 4 || i == Model.TotalPages - 3) { <span class="vr-sa-cell-muted px-2">...</span> }
                        continue;
                    }
                    <a class="vr-sa-pagebtn @(i == Model.Page ? "vr-sa-pagebtn-active" : "")" href="@Url.Action("Staff", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = i })">@i</a>
                }

                <a class="vr-sa-pagebtn" href="@Url.Action("Staff", "Admin", new { search = Model.Search, sort = Model.Sort, dir = Model.Dir, pageSize = Model.PageSize, page = next })" aria-disabled="@(Model.Page >= Model.TotalPages)">Next</a>
            </div>
        </div>
    </section>
</div>

<div class="modal fade vr-sa-modal" id="editStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Staff Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("UpdateStaff", "Admin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" id="vrEditStaffId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="vr-sa-label">Full Name</label>
                            <input type="text" name="FullName" id="vrEditStaffName" class="vr-sa-input" required />
                        </div>
                        <div class="col-md-8">
                            <label class="vr-sa-label">Role</label>
                            <select name="RoleId" id="vrEditStaffRole" class="vr-sa-input" required>
                                @foreach (var r in Model.AvailableRoles)
                                {
                                    <option value="@r.RoleId">@r.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="vr-sa-label">Status</label>
                            <select name="IsActive" id="vrEditStaffActive" class="vr-sa-input" required>
                                <option value="true">Authorized</option>
                                <option value="false">Revoked</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="addStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Staff Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("CreateStaff", "Admin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="vr-sa-label">Full Name</label>
                            <input type="text" name="FullName" class="vr-sa-input" placeholder="e.g. Maria Clara" required maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Email Address</label>
                            <input type="email" name="Email" class="vr-sa-input" placeholder="staff@hotel.com" required maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="vr-sa-label">Password</label>
                            <input type="password" name="Password" class="vr-sa-input" placeholder="••••••••" required minlength="6" />
                        </div>
                        <div class="col-12">
                            <label class="vr-sa-label">Assign Role</label>
                            <select name="RoleId" class="vr-sa-input" required>
                                @foreach (var r in Model.AvailableRoles)
                                {
                                    <option value="@r.RoleId">@r.RoleName</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary">Create Staff Member</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vr-sa-modal" id="archiveStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Archive Staff</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("DeleteStaff", "Admin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="vrArchiveStaffId" />
                <div class="modal-body">
                    <div class="text-center p-4">
                        <div style="width: 64px; height: 64px; background: rgba(245, 158, 11, 0.08); color: #f59e0b; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 1.5rem;">
                            <i class="fa-solid fa-box-archive"></i>
                        </div>
                        <h4 style="font-weight: 700; color: #0b122d; margin-bottom: 8px;">Archive this staff member?</h4>
                        <p style="color: #64748b; font-size: 0.95rem; line-height: 1.5;">You are about to archive <strong id="vrArchiveStaffName" style="color: #0b122d;">this user</strong>. This will revoke their access and hide them from active lists.</p>
                    </div>
                </div>
                <div class="modal-footer" style="justify-content: center; border-top: none; padding-bottom: 30px;">
                    <button type="button" class="vr-sa-btn" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
                    <button type="submit" class="vr-sa-btn vr-sa-btn-primary" style="background: #f59e0b; border-color: #f59e0b; min-width: 120px;">Confirm Archive</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const editStaffModal = document.getElementById('editStaffModal');
            if (editStaffModal) {
                editStaffModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    if (!btn) return;

                    document.getElementById('vrEditStaffId').value = btn.getAttribute('data-staff-id') || '';
                    document.getElementById('vrEditStaffName').value = btn.getAttribute('data-staff-name') || '';

                    const roleId = btn.getAttribute('data-staff-role') || '';
                    const roleSel = document.getElementById('vrEditStaffRole');
                    if (roleSel) roleSel.value = roleId;

                    const isActiveRaw = (btn.getAttribute('data-staff-active') || '').toLowerCase();
                    const isActive = isActiveRaw === 'true' || isActiveRaw === '1';
                    const activeSel = document.getElementById('vrEditStaffActive');
                    if (activeSel) activeSel.value = isActive ? 'true' : 'false';
                });
            }

            const archiveModal = document.getElementById('archiveStaffModal');
            if (archiveModal) {
                archiveModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    if (!btn) return;
                    document.getElementById('vrArchiveStaffId').value = btn.getAttribute('data-staff-id') || '';
                    document.getElementById('vrArchiveStaffName').textContent = btn.getAttribute('data-staff-name') || 'this user';
                });
            }
        })();
    </script>
}

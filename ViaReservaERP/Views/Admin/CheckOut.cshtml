@model ViaReservaERP.Models.Admin.CheckInViewModel
@{
    ViewData["Title"] = "Guest Departure (Check-Out)";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var balance = Model.TotalAmount - Model.TotalPaid;
}

<div class="vr-sa-panel" style="max-width: 800px; margin: 0 auto;">
    <div class="vr-sa-panel-head" style="margin-bottom: 30px;">
        <div>
            <div class="vr-sa-panel-title">Finalize Guest Departure</div>
            <div class="vr-sa-panel-sub">Reservation #@Model.Reservation.ReservationId — @Model.Reservation.Guest?.FullName</div>
        </div>
        <a href="@Url.Action("Details", "Admin", new { id = Model.Reservation.ReservationId })" class="vr-sa-btn">
            <i class="fa-solid fa-times me-2"></i> Cancel
        </a>
    </div>

    <div class="vr-sa-alert vr-sa-alert-info mb-4">
        <div class="vr-sa-alert-title">Financial Settlement Checklist</div>
        <div class="vr-sa-alert-sub">Please ensure all charges are settled before the guest leaves the property.</div>
    </div>

    <div class="row g-4">
        <!-- Settlement Summary -->
        <div class="col-md-7">
            <div class="vr-sa-panel" style="background: rgba(15, 23, 42, 0.02); border: 1px dashed rgba(15, 23, 42, 0.1);">
                <h5 style="font-weight: 700; color: #1e293b; margin-bottom: 20px;">Folio Summary</h5>
                
                <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                    <span class="text-muted">Stay & Room Charges</span>
                    <span style="font-weight: 600;">₱ @Model.TotalAmount.ToString("N2")</span>
                </div>
                
                <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                    <span class="text-muted">Total Payments Received</span>
                    <span class="text-success" style="font-weight: 600;">₱ @Model.TotalPaid.ToString("N2")</span>
                </div>

                <div class="d-flex justify-content-between pt-2">
                    <span style="font-weight: 800; color: #0b122d;">OUTSTANDING BALANCE</span>
                    <span style="font-weight: 800; color: @(balance > 0 ? "#ef4444" : "#10b981"); font-size: 1.2rem;">
                        ₱ @balance.ToString("N2")
                    </span>
                </div>
            </div>

            <div class="mt-4">
                <div class="vr-sa-tl-item">
                    <div class="vr-sa-tl-dot vr-sa-tl-insert"></div>
                    <div class="vr-sa-tl-body">
                        <div class="vr-sa-tl-title">Room @Model.AssignedRoomNumber</div>
                        <div class="vr-sa-tl-sub">Status: @Model.Reservation.Status</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Panel -->
        <div class="col-md-5">
            <div class="vr-sa-panel" style="background: white; height: 100%; border: 1px solid rgba(15, 23, 42, 0.05);">
                <h5 style="font-weight: 700; color: #0b122d; margin-bottom: 20px;">Departure Action</h5>
                
                @if (balance <= 0)
                {
                    <div class="vr-sa-alert vr-sa-alert-success mb-4">
                        <div class="vr-sa-alert-sub">Folio is fully settled. Guest is clear for departure.</div>
                    </div>

                    <form action="@Url.Action("ProcessCheckOut", "Admin")" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Reservation.ReservationId" />
                        
                        <div class="d-grid">
                            <button type="submit" class="vr-sa-btn vr-sa-btn-primary" style="height: 60px; font-size: 1.1rem;">
                                <i class="fa-solid fa-person-walking-luggage me-2"></i> Confirm Check-Out
                            </button>
                        </div>
                    </form>
                    <div class="mt-3 text-center">
                        <p class="small text-muted">Room @Model.AssignedRoomNumber will be marked as <strong>Available</strong> for new bookings.</p>
                    </div>
                }
                else
                {
                    <div class="vr-sa-alert vr-sa-alert-danger mb-4">
                        <div class="vr-sa-alert-title">Payment Required</div>
                        <div class="vr-sa-alert-sub">
                            The guest has an outstanding balance of ₱ @balance.ToString("N2"). 
                            Please process payment before finalizing check-out.
                        </div>
                    </div>
                    
                    <div class="d-grid gap-3">
                        <button class="vr-sa-btn" onclick="location.reload();">
                            <i class="fa-solid fa-credit-card me-2"></i> Post Payment
                        </button>
                        <a href="@Url.Action("Details", "Admin", new { id = Model.Reservation.ReservationId })" class="vr-sa-btn" style="justify-content: center;">
                            <i class="fa-solid fa-file-invoice-dollar me-2"></i> View Full Folio
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

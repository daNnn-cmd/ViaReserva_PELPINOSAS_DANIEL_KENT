@model ViaReservaERP.Models.SaaS.SubscriptionSuccessViewModel
@{
    ViewData["Title"] = "Success";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Subscription Activated - ViaReserva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --vr-navy: #0f2d57;
            --vr-gold: #c5a365;
            --vr-blue: #1e40af;
            --vr-light: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: url('/img/login-bg-modern.png') no-repeat center center fixed;
            background-size: cover;
            color: #334155;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .vr-page-overlay {
            position: fixed;
            inset: 0;
            background: linear-gradient(135deg, rgba(15,45,87,0.88) 0%, rgba(11,18,45,0.96) 100%);
            z-index: 0;
        }

        .vr-nav {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(15, 45, 87, 0.1);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .vr-nav-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--vr-navy);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .vr-nav-links a {
            color: #475569;
            font-weight: 600;
            text-decoration: none;
            margin-left: 2rem;
        }

        .vr-nav-links a:hover {
            color: var(--vr-navy);
        }

        .vr-btn-login {
            background: var(--vr-navy);
            color: white !important;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
        }

        .vr-btn-login:hover {
            background: var(--vr-blue);
        }

        .vr-shell {
            position: relative;
            z-index: 1;
            padding: 56px 16px 72px;
        }

        .vr-title {
            font-size: 2.25rem;
            font-weight: 900;
            line-height: 1.15;
            margin-bottom: 10px;
            background: linear-gradient(to right, #fff, var(--vr-gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }

        .vr-subtitle {
            color: rgba(255,255,255,0.82);
            line-height: 1.6;
            text-align: center;
            max-width: 820px;
            margin: 0 auto 18px;
        }

        .vr-card {
            max-width: 720px;
            margin: 0 auto;
            background: rgba(255,255,255,0.96);
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.4);
            box-shadow: 0 24px 48px rgba(0,0,0,0.35);
            overflow: hidden;
        }

        .vr-card-body {
            padding: 28px;
        }

        .vr-btn-primary {
            background: var(--vr-gold);
            color: var(--vr-navy);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 800;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            width: 100%;
        }

        .vr-btn-primary:hover {
            background: #d4b57b;
            color: var(--vr-navy);
        }
    </style>
</head>
<body>
    <div class="vr-page-overlay"></div>

    <nav class="vr-nav">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="@Url.Action("Index", "Home")" class="vr-nav-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" style="height: 32px;" />
                ViaReserva
            </a>
            <div class="vr-nav-links d-none d-md-flex align-items-center">
                <a href="@Url.Action("Index", "Home")#pricing">Pricing</a>
                <a href="@Url.Action("Privacy", "Home")">Privacy</a>
                <a href="@Url.Action("Login", "Account")" class="vr-btn-login">Sign In</a>
            </div>
        </div>
    </nav>

    <div class="vr-shell">
        <div class="vr-title">Subscription Activated</div>
        <div class="vr-subtitle">@Model.Message</div>

        <div class="vr-card">
            <div class="vr-card-body">
                @if (!string.IsNullOrWhiteSpace(Model.CompanyName))
                {
                    <div class="mb-2"><strong>Company:</strong> @Model.CompanyName</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.PlanName))
                {
                    <div class="mb-2"><strong>Plan:</strong> @Model.PlanName</div>
                }

                <a class="vr-btn-primary mt-3" href="@Url.Action("Login", "Account")">Go to Login</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

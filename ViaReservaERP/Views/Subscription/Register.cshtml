@model ViaReservaERP.Models.SaaS.SubscriptionRegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Start @Model.Plan - ViaReserva</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --vr-navy: #0f2d57;
            --vr-gold: #c5a365;
            --vr-blue: #1e40af;
            --vr-light: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: url('/img/login-bg-modern.png') no-repeat center center fixed;
            background-size: cover;
            color: #334155;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .vr-page-overlay {
            position: fixed;
            inset: 0;
            background: linear-gradient(135deg, rgba(15,45,87,0.88) 0%, rgba(11,18,45,0.96) 100%);
            z-index: 0;
        }

        .vr-nav {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(15, 45, 87, 0.1);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .vr-nav-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--vr-navy);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .vr-nav-links a {
            color: #475569;
            font-weight: 600;
            text-decoration: none;
            margin-left: 2rem;
        }

        .vr-nav-links a:hover {
            color: var(--vr-navy);
        }

        .vr-btn-login {
            background: var(--vr-navy);
            color: white !important;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
        }

        .vr-btn-login:hover {
            background: var(--vr-blue);
        }

        .vr-shell {
            position: relative;
            z-index: 1;
            padding: 48px 16px 72px;
        }

        .vr-headline {
            text-align: center;
            max-width: 820px;
            margin: 0 auto 22px;
        }

        .vr-title {
            font-size: 2.25rem;
            font-weight: 900;
            line-height: 1.15;
            margin-bottom: 10px;
            background: linear-gradient(to right, #fff, var(--vr-gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .vr-subtitle {
            color: rgba(255,255,255,0.82);
            line-height: 1.6;
        }

        .vr-card {
            max-width: 980px;
            margin: 0 auto;
            background: rgba(255,255,255,0.96);
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.4);
            box-shadow: 0 24px 48px rgba(0,0,0,0.35);
            overflow: hidden;
        }

        .vr-card-body {
            padding: 28px;
        }

        .form-label {
            font-weight: 700;
            color: var(--vr-navy);
            font-size: 0.92rem;
        }

        .form-control {
            border-radius: 12px;
            border: 1px solid rgba(15, 45, 87, 0.15);
            padding: 12px 14px;
        }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(197, 163, 101, 0.2);
            border-color: var(--vr-gold);
        }

        .vr-btn-primary {
            background: var(--vr-gold);
            color: var(--vr-navy);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 800;
            text-decoration: none;
        }

        .vr-btn-primary:hover {
            background: #d4b57b;
            color: var(--vr-navy);
        }

        .vr-muted {
            color: #64748b;
        }
    </style>
</head>
<body>
    <div class="vr-page-overlay"></div>

    <nav class="vr-nav">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="@Url.Action("Index", "Home")" class="vr-nav-brand">
                <img src="~/img/viareserva-logo.png" alt="ViaReserva" style="height: 32px;" />
                ViaReserva
            </a>
            <div class="vr-nav-links d-none d-md-flex align-items-center">
                <a href="@Url.Action("Index", "Home")#pricing">Pricing</a>
                <a href="@Url.Action("Privacy", "Home")">Privacy</a>
                <a href="@Url.Action("Login", "Account")" class="vr-btn-login">Sign In</a>
            </div>
        </div>
    </nav>

    <div class="vr-shell">
        <div class="vr-headline">
            <div class="vr-title">Start your @Model.Plan plan</div>
            <div class="vr-subtitle">Create your company and admin account, then continue to secure subscription payment.</div>
        </div>

        <div class="vr-card">
            <div class="vr-card-body">
                <form asp-action="Register" asp-controller="Subscription" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Plan" />

                    <div class="row g-3">
                        <div class="col-12">
                            <div style="font-weight: 900; color: var(--vr-navy);">Company details</div>
                            <div class="vr-muted" style="font-size: 0.95rem;">This will appear in your Super Admin monitoring and inside the platform.</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CompanyName" class="form-label"></label>
                            <input asp-for="CompanyName" class="form-control" />
                            <span asp-validation-for="CompanyName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="BusinessEmail" class="form-label">Business Email</label>
                            <input asp-for="BusinessEmail" class="form-control" />
                            <span asp-validation-for="BusinessEmail" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" type="tel" inputmode="numeric" pattern="\d{11}" maxlength="11" placeholder="09XXXXXXXXX" oninput="this.value = this.value.replace(/\D/g, '').slice(0, 11)" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NumberOfRooms" class="form-label"></label>
                            <input asp-for="NumberOfRooms" class="form-control" type="number" />
                            <span asp-validation-for="NumberOfRooms" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="HotelAddress" class="form-label"></label>
                            <input asp-for="HotelAddress" class="form-control" />
                            <span asp-validation-for="HotelAddress" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="BusinessType" class="form-label"></label>
                            <input asp-for="BusinessType" class="form-control" />
                            <span asp-validation-for="BusinessType" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="OwnerManagerName" class="form-label">Owner/Manager Name</label>
                            <input asp-for="OwnerManagerName" class="form-control" />
                            <span asp-validation-for="OwnerManagerName" class="text-danger"></span>
                        </div>

                        <div class="col-12 pt-2">
                            <hr class="my-2" />
                            <div style="font-weight: 900; color: var(--vr-navy);">Company admin account</div>
                            <div class="vr-muted" style="font-size: 0.95rem;">This account will manage rooms, staff, and operations after activation.</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AdminFullName" class="form-label">Full Name</label>
                            <input asp-for="AdminFullName" class="form-control" />
                            <span asp-validation-for="AdminFullName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AdminEmail" class="form-label">Email</label>
                            <input asp-for="AdminEmail" class="form-control" />
                            <span asp-validation-for="AdminEmail" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="vr-btn-primary w-100">Continue to Payment</button>
                        </div>

                        <div class="col-12 text-center" style="font-size: 0.95rem;">
                            <a href="@Url.Action("Login", "Account")" style="color: var(--vr-gold); font-weight: 700; text-decoration: none;">Already have an account? Sign in</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
